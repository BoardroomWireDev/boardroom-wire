# Public env var — exposed to client-side code (visible in built JS).
# Restrict the key to your domains in Google Cloud Console under
# "Credentials → API key → Application restrictions → HTTP referrers":
#   localhost:*
#   127.0.0.1:*
#   boardroomwire.com/*
#   www.boardroomwire.com/*
#
# How to get one:
#   1. https://console.cloud.google.com/ → Create project
#   2. APIs & Services → Library → enable "YouTube Data API v3"
#   3. Credentials → Create credentials → API key
#   4. Copy here as PUBLIC_YOUTUBE_API_KEY=<your key>
#   5. cp .env.example .env  (then edit .env with your real key)
#
# Without a key the homepage ticker shows "—" stats and the carousel
# renders 6 placeholder cards. Both pages still build and serve.
PUBLIC_YOUTUBE_API_KEY=
