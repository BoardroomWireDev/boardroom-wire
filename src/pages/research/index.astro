---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ResearchCard from '../../components/ResearchCard.astro';

const research = (
  await getCollection('research', ({ data }) => !data.draft)
).sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout
  title="Research"
  description="Research dashboards and forensic analyses from Boardroom Wire — the numbers behind the AI industry, decoded."
>
  <main class="mx-auto max-w-screen-2xl px-6 py-16 md:py-24">
    <header class="mb-12 max-w-3xl">
      <p class="text-xs uppercase tracking-wider text-gold">Research</p>
      <h1 class="mt-4 font-serif text-4xl text-cream md:text-6xl">
        The numbers tell the story.
      </h1>
      <p class="mt-6 text-lg text-cream-muted">
        Dashboards and primary-source analyses on AI companies, private
        markets, and titan strategy.
      </p>
    </header>

    {
      research.length === 0 ? (
        <p class="text-cream-muted">
          Dashboards in progress — first batch lands soon.
        </p>
      ) : (
        <div class="grid gap-8 md:grid-cols-2">
          {research.map((entry) => (
            <ResearchCard entry={entry} />
          ))}
        </div>
      )
    }
  </main>
</BaseLayout>
