---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import VideoCard from '../../components/VideoCard.astro';
import ResearchCard from '../../components/ResearchCard.astro';

export async function getStaticPaths() {
  return [
    { slug: 'business-of-ai', label: 'Business of AI' },
    { slug: 'private-markets', label: 'Private Markets' },
    { slug: 'titan-strategy', label: 'Titan Strategy' },
    { slug: 'market-dynamics', label: 'Market Dynamics' },
  ].map((c) => ({ params: { category: c.slug }, props: { label: c.label } }));
}

const { category } = Astro.params;
const { label } = Astro.props;

const filterByCategory = ({ data }: { data: { category: string; draft: boolean } }) =>
  !data.draft && data.category === category;

const sortByDateDesc = (
  a: { data: { publishDate: Date } },
  b: { data: { publishDate: Date } },
) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf();

const articles = (await getCollection('articles', filterByCategory)).sort(
  sortByDateDesc,
);
const videos = (await getCollection('videos', filterByCategory)).sort(
  sortByDateDesc,
);
const research = (await getCollection('research', filterByCategory)).sort(
  sortByDateDesc,
);

const total = articles.length + videos.length + research.length;
---

<BaseLayout
  title={label}
  description={`Boardroom Wire coverage in ${label} — articles, videos, and research dashboards.`}
>
  <main class="mx-auto max-w-screen-2xl px-6 py-16 md:py-24">
    <header class="mb-12 max-w-3xl">
      <p class="text-xs uppercase tracking-wider text-gold">Category</p>
      <h1 class="mt-4 font-serif text-4xl text-cream md:text-6xl">{label}</h1>
    </header>

    {
      total === 0 ? (
        <p class="text-cream-muted">
          No coverage in this pillar yet — check back soon.
        </p>
      ) : (
        <div class="space-y-16">
          {articles.length > 0 && (
            <section>
              <h2 class="mb-8 font-serif text-3xl text-cream md:text-4xl">
                Articles
              </h2>
              <div class="grid gap-8 md:grid-cols-3">
                {articles.map((entry) => (
                  <ArticleCard entry={entry} />
                ))}
              </div>
            </section>
          )}

          {videos.length > 0 && (
            <section>
              <h2 class="mb-8 font-serif text-3xl text-cream md:text-4xl">
                Videos
              </h2>
              <div class="grid gap-8 md:grid-cols-3">
                {videos.map((entry) => (
                  <VideoCard entry={entry} />
                ))}
              </div>
            </section>
          )}

          {research.length > 0 && (
            <section>
              <h2 class="mb-8 font-serif text-3xl text-cream md:text-4xl">
                Research
              </h2>
              <div class="grid gap-8 md:grid-cols-2">
                {research.map((entry) => (
                  <ResearchCard entry={entry} />
                ))}
              </div>
            </section>
          )}
        </div>
      )
    }
  </main>
</BaseLayout>
