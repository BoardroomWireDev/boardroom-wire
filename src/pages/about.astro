---
// About page — shares the ticker shell + YouTube data fetcher with the homepage.
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About · Boardroom Wire</title>
  <meta name="description" content="Boardroom Wire is forensic business analysis of AI companies and tech industry developments — Bloomberg-style depth, PE/banker lens, no hype." />
  <link rel="icon" type="image/png" href="/logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

  <style>
    :root {
      --black:       #000000;
      --black-soft:  #0A0A0A;
      --line:        #1A1A1A;
      --white:       #F5F1E5;
      --white-dim:   #888173;
      --gold:        #D4AF37;
      --gold-bright: #F2CB52;
      --amber:        #FFB347;
      --amber-bright: #FFC97A;
      --amber-glow:   rgba(255, 179, 71, 0.4);
      --display: 'Inter', system-ui, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--black);
      color: var(--white);
      font-family: var(--display);
      overflow-x: hidden;
      min-height: 100vh;
    }

    body::before {
      content: "";
      position: fixed; inset: 0;
      pointer-events: none;
      z-index: 1000;
      opacity: 0.04;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.6'/%3E%3C/svg%3E");
    }

    .ticker {
      display: flex;
      align-items: stretch;
      height: 54px;
      border-bottom: 1px solid var(--line);
      background: var(--black);
      position: relative;
      z-index: 10;
    }
    .ticker-label {
      background: var(--gold);
      color: var(--black);
      font-family: var(--display);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.24em;
      padding: 0 22px;
      display: flex;
      align-items: center;
      gap: 12px;
      text-transform: uppercase;
      box-shadow: 0 0 14px var(--amber-glow);
    }
    .ticker-label .pulse {
      width: 9px; height: 9px;
      background: #FF3B30;
      border-radius: 50%;
      box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7);
      filter: drop-shadow(0 0 4px rgba(255, 59, 48, 0.55));
      animation: pulse-red 1.4s ease-in-out infinite;
    }
    @keyframes pulse-red {
      0%   { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7); opacity: 1; }
      70%  { box-shadow: 0 0 0 10px rgba(255, 59, 48, 0); opacity: 0.85; }
      100% { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0); opacity: 1; }
    }
    .ticker-stats {
      flex: 1;
      overflow: hidden;
      position: relative;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
              mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
    }
    .ticker-track {
      display: flex;
      align-items: center;
      gap: 56px;
      height: 100%;
      width: max-content;
      padding-left: 32px;
      animation: ticker-scroll 28s linear infinite;
    }
    .ticker:hover .ticker-track,
    .ticker:focus-within .ticker-track {
      animation-play-state: paused;
    }
    @keyframes ticker-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .stat {
      font-family: var(--display);
      font-size: 13px;
      letter-spacing: 0.18em;
      color: var(--white-dim);
      text-transform: uppercase;
      font-weight: 500;
      display: flex;
      align-items: baseline;
      gap: 12px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .stat .v {
      color: var(--white);
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .stat.live .v.on  { color: var(--gold-bright); }
    .stat.live .v.off { color: var(--white-dim); }
    .stat .sep {
      color: var(--line);
      margin-left: 56px;
    }

    header.top {
      padding: 32px 48px 0;
      position: relative;
      z-index: 5;
    }
    .home-link {
      font-family: var(--display);
      font-weight: 900;
      font-size: 22px;
      letter-spacing: 0.02em;
      line-height: 1;
      color: var(--white);
      text-decoration: none;
      user-select: none;
    }
    .home-link .wire { color: var(--gold-bright); }
    .home-link:hover .wire { color: var(--gold); }

    main.about {
      max-width: 720px;
      margin: 0 auto;
      padding: 88px 32px 96px;
      position: relative;
      z-index: 5;
    }
    .eyebrow {
      font-family: var(--display);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.32em;
      color: var(--gold-bright);
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .headline {
      font-family: var(--display);
      font-weight: 600;
      font-size: clamp(36px, 5vw, 56px);
      line-height: 1.05;
      letter-spacing: -0.02em;
      margin-bottom: 32px;
    }
    .headline em {
      font-style: italic;
      color: var(--gold-bright);
    }
    .lede {
      font-family: var(--display);
      font-weight: 400;
      font-size: clamp(18px, 2vw, 22px);
      line-height: 1.55;
      color: var(--white);
      margin-bottom: 56px;
      max-width: 560px;
    }
    .body p {
      font-family: var(--display);
      font-size: clamp(16px, 1.5vw, 18px);
      line-height: 1.7;
      color: var(--white-dim);
      margin-bottom: 22px;
    }
    /* Phosphor pull-forward — emphasis goes amber with a soft text-shadow halo
       so the prose has CRT-style "lit" accents. Body remains dim for contrast. */
    .body strong {
      color: var(--amber-bright);
      font-weight: 700;
      text-shadow: 0 0 14px rgba(255, 179, 71, 0.65);
    }
    .body em {
      font-style: italic;
      color: var(--amber);
      text-shadow: 0 0 10px rgba(255, 179, 71, 0.45);
    }
    .section-h {
      font-family: var(--display);
      font-weight: 700;
      font-size: 14px;
      letter-spacing: 0.22em;
      color: var(--gold);
      text-transform: uppercase;
      margin: 48px 0 18px;
    }
    /* Editorial section markers (§ 00 — Standfirst, § 01 — Mission, etc.) */
    .section-marker {
      display: flex;
      align-items: baseline;
      gap: 14px;
      margin: 64px 0 24px;
      padding-top: 28px;
      border-top: 1px solid var(--line);
    }
    .section-marker:first-of-type {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
    }
    .section-marker .num {
      font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.16em;
      color: var(--amber-bright);
      text-shadow: 0 0 16px rgba(255, 179, 71, 0.7);
    }
    .section-marker .name {
      font-family: var(--display);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--white);
    }
    .standfirst {
      font-family: var(--display);
      font-size: clamp(20px, 2.4vw, 26px);
      font-weight: 600;
      line-height: 1.35;
      letter-spacing: -0.01em;
      color: var(--white);
      margin-bottom: 18px;
      text-shadow: 0 0 28px rgba(255, 179, 71, 0.32);
    }
    .signoff {
      margin-top: 80px;
      padding-top: 32px;
      border-top: 1px solid var(--line);
      font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      color: var(--amber);
      text-align: center;
      text-transform: uppercase;
    }
    .signoff .sep {
      color: var(--white-dim);
      margin: 0 14px;
    }
    .signoff .blink {
      animation: signoff-blink 1s step-end infinite;
    }
    @keyframes signoff-blink {
      0%, 50%   { opacity: 1; }
      50.01%, 100% { opacity: 0; }
    }

    /* CRT atmosphere — fixed overlay with scanlines + corner phosphor glow.
       Scoped to about page only via the .page-fx element rendered there. */
    .page-fx {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background:
        radial-gradient(circle at 0% 0%,   rgba(255, 179, 71, 0.14), transparent 35%),
        radial-gradient(circle at 100% 0%, rgba(255, 179, 71, 0.10), transparent 35%),
        radial-gradient(circle at 0% 100%, rgba(255, 179, 71, 0.10), transparent 35%),
        radial-gradient(circle at 100% 100%, rgba(255, 179, 71, 0.14), transparent 35%),
        repeating-linear-gradient(
          to bottom,
          rgba(255, 179, 71, 0.035) 0,
          rgba(255, 179, 71, 0.035) 1px,
          transparent 1px,
          transparent 4px
        );
    }
    .body ul {
      list-style: none;
      padding: 0;
      margin: 0 0 28px;
    }
    .body li {
      font-family: var(--display);
      font-size: clamp(16px, 1.5vw, 18px);
      line-height: 1.6;
      color: var(--white-dim);
      padding-left: 24px;
      position: relative;
      margin-bottom: 14px;
    }
    .body li::before {
      content: "";
      position: absolute;
      left: 0; top: 0.7em;
      width: 12px; height: 1px;
      background: var(--gold);
    }
    .body li strong {
      color: var(--white);
      font-weight: 600;
    }

    .find-us-bottom {
      margin-top: 72px;
      padding-top: 40px;
      border-top: 1px solid var(--line);
    }
    .find-us-label {
      font-family: var(--display);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.28em;
      color: var(--white-dim);
      text-transform: uppercase;
      margin-bottom: 24px;
    }
    .socials {
      display: flex;
      gap: 28px;
      align-items: center;
    }
    .socials a {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      color: var(--white);
      transition: all 0.2s;
      text-decoration: none;
    }
    .socials a:hover {
      color: var(--gold-bright);
      transform: translateY(-2px);
    }
    .socials svg { width: 22px; height: 22px; fill: currentColor; }

    footer.tail {
      border-top: 1px solid var(--line);
      padding: 28px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      font-family: var(--display);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white-dim);
    }
    footer.tail a {
      color: inherit;
      text-decoration: none;
      transition: color 0.18s;
    }
    footer.tail a:hover { color: var(--gold-bright); }

    @media (max-width: 720px) {
      header.top { padding: 20px 24px 0; }
      .home-link { font-size: 18px; }
      .ticker { height: 46px; }
      .ticker-track { gap: 36px; padding-left: 20px; }
      .stat { font-size: 11px; letter-spacing: 0.12em; gap: 8px; }
      .stat .sep { margin-left: 36px; }
      .ticker-label { font-size: 11px; padding: 0 14px; gap: 8px; }
      .ticker-label .pulse { width: 8px; height: 8px; }
      main.about { padding: 64px 24px 80px; }
      footer.tail { padding: 20px 24px; flex-direction: column; align-items: flex-start; gap: 12px; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0s !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0s !important;
      }
      .ticker-track {
        animation: ticker-scroll 28s linear infinite !important;
      }
    }
  </style>
</head>
<body>

  <!-- CRT phosphor atmosphere overlay (about-page only) -->
  <div class="page-fx" aria-hidden="true"></div>

  <div class="ticker">
    <div class="ticker-label">
      <span class="pulse"></span>
      <span>Live Wire</span>
    </div>
    <div class="ticker-stats" aria-label="Live channel statistics">
      <div class="ticker-track">
        <div class="stat">Videos <span class="v" data-stat="videos">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Subscribers <span class="v" data-stat="subs">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Total Views <span class="v" data-stat="views">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Top Episode <span class="v" data-stat="top">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Newest <span class="v" data-stat="newest">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat" aria-hidden="true">Videos <span class="v" data-stat="videos">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Subscribers <span class="v" data-stat="subs">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Total Views <span class="v" data-stat="views">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Top Episode <span class="v" data-stat="top">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Newest <span class="v" data-stat="newest">—</span><span class="sep">·</span></div>
      </div>
    </div>
  </div>

  <header class="top">
    <a href="/" class="home-link" aria-label="Boardroom Wire — home">
      BOARDROOM<span class="wire">WIRE</span>
    </a>
  </header>

  <main class="about">
    <p class="eyebrow">About</p>

    <div class="body">
      <div class="section-marker">
        <span class="num">§ 00</span>
        <span class="name">Standfirst</span>
      </div>
      <p class="standfirst">
        Boardroom Wire is forensic analysis of the companies shaping the future of AI and technology.
      </p>
      <p>
        Bloomberg-grade depth, applied to a beat that mostly gets covered in screenshots and hot takes. Strategic breakdowns, not product reviews. Frameworks, not vibes.
      </p>

      <div class="section-marker">
        <span class="num">§ 01</span>
        <span class="name">Mission</span>
      </div>
      <p>
        Most coverage of the AI industry stops at <em>this looks cool</em> or <em>this looks dangerous</em>. Boardroom Wire starts where that coverage ends — with the cap tables, the unit economics, the structural exposures, and the strategic logic. Who is actually winning. Who is being recapitalized in slow motion. What the data rooms look like behind the press release. What any of it means for the next decade of the industry.
      </p>
      <p>
        The premise is that AI is now a capital markets story as much as a technology story, and the audience sophisticated enough to want it covered that way is underserved.
      </p>

      <div class="section-marker">
        <span class="num">§ 02</span>
        <span class="name">Method</span>
      </div>
      <p>
        Three rules govern every dispatch.
      </p>
      <p>
        <strong>Evidence first.</strong> Every claim is sourced. Where the source is a 10-K, a deck, a transcript, a public filing, or a primary interview, it is named. Speculation is labeled as speculation.
      </p>
      <p>
        <strong>Frameworks over takes.</strong> A take ages in a week. A framework — the structural lens through which to read the next ten developments — ages in years. Boardroom Wire ships frameworks.
      </p>
      <p>
        <strong>Compression.</strong> Every sentence earns its place. The reader's time is the scarcest resource on the page.
      </p>

      <div class="section-marker">
        <span class="num">§ 03</span>
        <span class="name">Editorial Independence</span>
      </div>
      <p>
        Boardroom Wire takes no sponsorships from companies it covers. No paid placements. No pre-publication review by subjects. Disclosures, when relevant, run inline with the dispatch.
      </p>

      <p class="signoff">
        <span>Boardroom Wire</span>
        <span class="sep">·</span>
        <span>New York</span>
        <span class="sep">·</span>
        <span id="signoff-time">--<span class="blink">:</span>-- EDT</span>
        <span class="sep">·</span>
        <span>Dispatch N° 0001</span>
      </p>
    </div>

    <div class="find-us-bottom">
      <div class="find-us-label">Find Boardroom Wire</div>
      <div class="socials">
        <a href="https://x.com/BoardroomWire" target="_blank" rel="noopener" title="X" aria-label="X">
          <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://www.youtube.com/@BoardroomWire" target="_blank" rel="noopener" title="YouTube" aria-label="YouTube">
          <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://substack.com/@boardroom1" target="_blank" rel="noopener" title="Substack" aria-label="Substack">
          <svg viewBox="0 0 24 24"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
        </a>
      </div>
    </div>
  </main>

  <footer class="tail">
    <span>© 2026 Boardroom Wire</span>
    <a href="/">← Home</a>
  </footer>

  <script>
    import { fetchChannelData, fmt, daysAgo } from '../lib/youtube';

    const setStat = (name: string, value: string) => {
      document.querySelectorAll(`[data-stat="${name}"]`).forEach((el) => {
        el.textContent = value;
      });
    };

    async function hydrate() {
      const data = await fetchChannelData();
      if (!data) return; // ticker shows em-dashes
      setStat('videos', fmt(data.videos));
      setStat('subs',   fmt(data.subs));
      setStat('views',  fmt(data.views));
      setStat('top',    data.topVideo ? `${fmt(data.topVideo.views)} views` : '—');
      setStat('newest', data.newest ? daysAgo(data.newest.publishedAt) : '—');
    }
    hydrate();
    setInterval(hydrate, 5 * 60_000);

    // Live terminal-style signoff: NYC time updates every 30s, the colon
    // between hours and minutes blinks once per second via CSS animation.
    function updateSignoffTime() {
      const el = document.getElementById('signoff-time');
      if (!el) return;
      const parts = new Intl.DateTimeFormat('en-US', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
        timeZone: 'America/New_York',
        timeZoneName: 'short',
      }).formatToParts(new Date());
      const hour = parts.find((p) => p.type === 'hour')?.value ?? '--';
      const minute = parts.find((p) => p.type === 'minute')?.value ?? '--';
      const tz = parts.find((p) => p.type === 'timeZoneName')?.value ?? 'EDT';
      el.innerHTML = `${hour}<span class="blink">:</span>${minute} ${tz}`;
    }
    updateSignoffTime();
    setInterval(updateSignoffTime, 30_000);
  </script>
</body>
</html>
