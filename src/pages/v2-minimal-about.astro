---
import ModernLayout from '../layouts/ModernLayout.astro';
import SocialRow from '../components/SocialRow.astro';
import DesignControls from '../components/DesignControls.astro';
---

<ModernLayout
  title="About"
  description="Boardroom Wire is forensic business analysis of AI companies and tech industry developments — Bloomberg-style depth, PE/banker lens, no hype."
  variant="minimal"
>
  {/* Backdrops (same set as homepage so the saved choice persists) */}
  <div class="backdrops pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div class="backdrop" data-backdrop-key="mesh">
      <div class="absolute top-0 left-1/4 h-[800px] w-[800px] rounded-full bg-electric/20 blur-3xl animate-mesh-drift"></div>
      <div class="absolute top-1/3 right-1/5 h-[600px] w-[600px] rounded-full bg-electric/15 blur-3xl animate-mesh-drift" style="animation-delay: -8s"></div>
      <div class="absolute bottom-0 left-1/2 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-electric/10 blur-3xl animate-mesh-drift" style="animation-delay: -16s"></div>
    </div>
    <div class="backdrop bg-grid" data-backdrop-key="grid"></div>
    <div class="backdrop bg-noise" data-backdrop-key="noise">
      <div class="absolute inset-0 bg-scanline"></div>
    </div>
    <div class="backdrop" data-backdrop-key="layered">
      <div class="absolute inset-0 bg-grid opacity-50"></div>
      <div class="absolute top-0 left-1/4 h-[800px] w-[800px] rounded-full bg-electric/20 blur-3xl animate-mesh-drift"></div>
      <div class="absolute top-1/3 right-1/5 h-[600px] w-[600px] rounded-full bg-electric/15 blur-3xl animate-mesh-drift" style="animation-delay: -8s"></div>
    </div>
  </div>

  <div class="absolute left-6 top-14 z-10 md:left-10 md:top-16">
    <a href="/v2-minimal/" class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-ink-border bg-ink-elevated/40 font-modern text-sm font-bold tracking-tight text-paper transition-colors hover:border-electric/60 hover:text-electric">
      <span>B<span class="text-electric">W</span></span>
    </a>
  </div>

  <main class="relative">
    <section class="px-6 pb-12 pt-32 md:pt-40">
      <div class="mx-auto max-w-3xl">
        <p class="reveal text-xs font-mono uppercase tracking-[0.3em] text-paper-dim">About</p>

        <div class="reveal mt-6" style="transition-delay: 100ms">
          <h1 data-wordmark-key="1" class="wordmark font-modern text-5xl font-bold leading-[0.9] tracking-tight md:text-7xl">
            <span>Boardroom</span><span class="text-electric">Wire</span>
          </h1>
          <h1 data-wordmark-key="2" class="wordmark font-modern text-4xl font-bold uppercase leading-[0.95] tracking-[0.02em] md:text-6xl">
            Boardroom Wire
          </h1>
          <h1 data-wordmark-key="3" class="wordmark font-modern text-5xl font-bold uppercase leading-[0.9] tracking-tight md:text-7xl">
            <span>Boardroom</span><span class="text-electric">Wire</span>
          </h1>
        </div>

        <p class="reveal mt-8 text-2xl leading-snug text-paper md:text-3xl" style="transition-delay: 200ms">
          Forensic analysis of the companies shaping the future.
        </p>

        <div class="reveal mt-12 space-y-6 text-base leading-relaxed text-paper-dim md:text-lg" style="transition-delay: 300ms">
          <p>
            Most AI coverage stops at "this looks cool" or "this looks dangerous." Boardroom Wire
            starts where that coverage ends — with the numbers, the structure, and the strategic
            logic. Who's winning, who's being recapitalized in slow motion, what the data rooms
            look like, and what it all means for the next ten years of the industry.
          </p>
          <p>
            Bloomberg-style depth on AI and the tech industry, with the lens of an analyst who's
            spent the last eight years selling into the firms that quietly shape the deals you
            read about three quarters later.
          </p>
          <p>
            Strategic breakdowns, not product reviews. Frameworks, not hot takes. The numbers
            tell the story.
          </p>
        </div>

        <div class="reveal mt-14 flex flex-wrap items-center gap-6" style="transition-delay: 400ms">
          <SocialRow moreInfoHref="/v2-minimal/" />
        </div>

        <p class="reveal mt-8 text-xs text-paper-dim/60" style="transition-delay: 500ms">
          (The "More info" pill above goes back to the homepage from here.)
        </p>
      </div>
    </section>

    <footer class="mt-24 border-t border-ink-border/60">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-8 text-xs text-paper-dim md:flex-row md:items-center md:justify-between">
        <span>© 2026 Boardroom Wire</span>
        <div class="flex gap-5">
          <a href="/rss.xml" class="hover:text-paper">RSS</a>
          <a href="/v2-minimal/" class="hover:text-paper">Home</a>
        </div>
      </div>
    </footer>
  </main>

  <DesignControls />
</ModernLayout>

<style is:global>
  .wordmark { display: none; }
  html[data-wordmark="1"] [data-wordmark-key="1"],
  html[data-wordmark="2"] [data-wordmark-key="2"],
  html[data-wordmark="3"] [data-wordmark-key="3"],
  html:not([data-wordmark]) [data-wordmark-key="1"] {
    display: block;
  }

  .backdrop {
    display: none;
    position: absolute;
    inset: 0;
  }
  html[data-backdrop="mesh"] [data-backdrop-key="mesh"],
  html[data-backdrop="grid"] [data-backdrop-key="grid"],
  html[data-backdrop="noise"] [data-backdrop-key="noise"],
  html[data-backdrop="layered"] [data-backdrop-key="layered"],
  html:not([data-backdrop]) [data-backdrop-key="mesh"] {
    display: block;
  }

  .bg-grid {
    background-color: #0a0d18;
    background-image:
      linear-gradient(rgb(96 165 250 / 0.22) 1px, transparent 1px),
      linear-gradient(90deg, rgb(96 165 250 / 0.22) 1px, transparent 1px);
    background-size: 40px 40px;
    background-position: -1px -1px;
    -webkit-mask-image: radial-gradient(ellipse at center, #000 35%, transparent 90%);
            mask-image: radial-gradient(ellipse at center, #000 35%, transparent 90%);
  }
  .bg-noise {
    background-color: #0a0a14;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.6 0 0 0 0 0.7 0 0 0 0 1 0 0 0 0.55 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
  }
  .bg-scanline {
    background-image: repeating-linear-gradient(
      to bottom,
      rgb(96 165 250 / 0.1) 0,
      rgb(96 165 250 / 0.1) 1px,
      transparent 1px,
      transparent 3px
    );
    animation: scanline-drift 6s linear infinite;
  }
  @keyframes scanline-drift {
    from { background-position: 0 0; }
    to { background-position: 0 60px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-scanline { animation: none; }
  }
</style>
