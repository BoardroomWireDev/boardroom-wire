---
// Videos page — same ticker / wordmark / footer shell as about.astro, with
// the YouTube reel carousel as the body. Hydrated from src/lib/youtube.ts.
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Videos · Boardroom Wire</title>
  <meta name="description" content="Latest video analysis from Boardroom Wire — strategic breakdowns of business and technology, refreshed live from the YouTube channel." />
  <link rel="icon" type="image/png" href="/logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

  <style>
    :root {
      --black:       #000000;
      --black-soft:  #0A0A0A;
      --line:        #1A1A1A;
      --white:       #F5F1E5;
      --white-dim:   #888173;
      --gold:        #D4AF37;
      --gold-bright: #F2CB52;
      --amber:        #FFB347;
      --amber-bright: #FFC97A;
      --amber-glow:   rgba(255, 179, 71, 0.4);
      --display: 'Inter', system-ui, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--black);
      color: var(--white);
      font-family: var(--display);
      overflow-x: hidden;
      min-height: 100vh;
    }

    body::before {
      content: "";
      position: fixed; inset: 0;
      pointer-events: none;
      z-index: 1000;
      opacity: 0.04;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.6'/%3E%3C/svg%3E");
    }

    /* ============ TICKER ============ */
    .ticker {
      display: flex;
      align-items: stretch;
      height: 54px;
      border-bottom: 1px solid var(--line);
      background: var(--black);
      position: relative;
      z-index: 10;
    }
    .ticker-label {
      background: var(--gold);
      color: var(--black);
      font-family: var(--display);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.24em;
      padding: 0 22px;
      display: flex;
      align-items: center;
      gap: 12px;
      text-transform: uppercase;
      box-shadow: 0 0 14px var(--amber-glow);
    }
    .ticker-label .pulse {
      width: 9px; height: 9px;
      background: #FF3B30;
      border-radius: 50%;
      box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7);
      filter: drop-shadow(0 0 4px rgba(255, 59, 48, 0.55));
      animation: pulse-red 1.4s ease-in-out infinite;
    }
    @keyframes pulse-red {
      0%   { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7); opacity: 1; }
      70%  { box-shadow: 0 0 0 10px rgba(255, 59, 48, 0); opacity: 0.85; }
      100% { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0); opacity: 1; }
    }
    .ticker-stats {
      flex: 1;
      overflow: hidden;
      position: relative;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
              mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
    }
    .ticker-track {
      display: flex;
      align-items: center;
      gap: 56px;
      height: 100%;
      width: max-content;
      padding-left: 32px;
      animation: ticker-scroll 28s linear infinite;
    }
    .ticker:hover .ticker-track,
    .ticker:focus-within .ticker-track {
      animation-play-state: paused;
    }
    @keyframes ticker-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .stat {
      font-family: var(--display);
      font-size: 13px;
      letter-spacing: 0.18em;
      color: var(--white-dim);
      text-transform: uppercase;
      font-weight: 500;
      display: flex;
      align-items: baseline;
      gap: 12px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .stat .v {
      color: var(--white);
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .stat .sep {
      color: var(--line);
      margin-left: 56px;
    }

    /* ============ HEADER ============ */
    header.top {
      padding: 32px 48px 0;
      position: relative;
      z-index: 5;
    }
    .home-link {
      font-family: var(--display);
      font-weight: 900;
      font-size: 22px;
      letter-spacing: 0.02em;
      line-height: 1;
      color: var(--white);
      text-decoration: none;
      user-select: none;
    }
    .home-link .wire { color: var(--gold-bright); }
    .home-link:hover .wire { color: var(--gold); }

    /* ============ PAGE HEADING ============ */
    main.videos-page {
      max-width: 1280px;
      margin: 0 auto;
      padding: 56px 48px 24px;
      position: relative;
      z-index: 5;
    }
    .page-eyebrow {
      font-family: var(--display);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.32em;
      color: var(--gold-bright);
      text-transform: uppercase;
      margin-bottom: 20px;
    }
    .page-heading {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(40px, 5.5vw, 72px);
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--white);
      margin-bottom: 12px;
    }
    .page-heading .accent { color: var(--gold-bright); font-style: italic; }
    .page-sub {
      font-family: var(--display);
      font-size: clamp(15px, 1.5vw, 18px);
      font-weight: 400;
      color: var(--white-dim);
      max-width: 640px;
      line-height: 1.5;
    }

    /* ============ REEL ============ */
    section.reel {
      padding: 48px 0 80px;
      position: relative;
      z-index: 5;
    }
    .reel-controls {
      max-width: 1280px;
      margin: 0 auto 24px;
      padding: 0 48px;
      display: flex;
      gap: 8px;
      justify-content: flex-end;
    }
    .reel-btn {
      width: 44px; height: 44px;
      border: 1px solid var(--line);
      background: transparent;
      color: var(--white);
      cursor: pointer;
      transition: all 0.18s;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .reel-btn:hover {
      border-color: var(--gold);
      color: var(--gold-bright);
    }
    .reel-btn svg { width: 18px; height: 18px; fill: currentColor; }
    .reel-track-wrap {
      position: relative;
      overflow: hidden;
    }
    .reel-track {
      display: flex;
      gap: 20px;
      padding: 0 48px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .reel-track::-webkit-scrollbar { display: none; }
    .reel-card {
      scroll-snap-align: start;
      flex: 0 0 calc((100% - 48px*2 - 20px*2) / 3);
      min-width: 280px;
      max-width: 480px;
      position: relative;
      display: block;
      text-decoration: none;
      color: var(--white);
      border: 1px solid var(--line);
      background: var(--black-soft);
      transition: border-color 0.2s, transform 0.25s;
    }
    .reel-card:hover {
      border-color: var(--gold);
      transform: translateY(-3px);
    }
    .reel-card .thumb {
      position: relative;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: var(--black-soft);
    }
    .reel-card .thumb img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s;
    }
    .reel-card:hover .thumb img { transform: scale(1.04); }
    .reel-card .thumb::after {
      content: "";
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 50%);
      pointer-events: none;
    }
    .reel-card .play {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.25s;
      pointer-events: none;
    }
    .reel-card:hover .play { opacity: 1; }
    .reel-card .play span {
      width: 64px; height: 64px;
      background: var(--gold-bright);
      color: var(--black);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .reel-card .play svg { width: 24px; height: 24px; margin-left: 4px; fill: currentColor; }
    .reel-card .meta {
      padding: 18px 20px 22px;
      position: relative;
    }
    .reel-card .meta h3 {
      font-family: var(--display);
      font-size: 16px;
      font-weight: 600;
      line-height: 1.35;
      color: var(--white);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .reel-card.placeholder .thumb {
      background: linear-gradient(135deg, #0a0a0a, #1a1a1a 50%, #0a0a0a);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .reel-card.placeholder .thumb::before {
      content: "";
      width: 56px; height: 56px;
      border: 1px solid var(--line);
      border-radius: 50%;
      background: rgba(212, 175, 55, 0.04);
    }

    /* ============ FOOTER ============ */
    footer.tail {
      border-top: 1px solid var(--line);
      padding: 28px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      font-family: var(--display);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white-dim);
    }
    footer.tail a {
      color: inherit;
      text-decoration: none;
      transition: color 0.18s;
    }
    footer.tail a:hover { color: var(--gold-bright); }

    @media (max-width: 720px) {
      header.top { padding: 20px 24px 0; }
      .home-link { font-size: 18px; }
      .ticker { height: 46px; }
      .ticker-track { gap: 36px; padding-left: 20px; }
      .stat { font-size: 11px; letter-spacing: 0.12em; gap: 8px; }
      .stat .sep { margin-left: 36px; }
      .ticker-label { font-size: 11px; padding: 0 14px; gap: 8px; }
      .ticker-label .pulse { width: 8px; height: 8px; }
      main.videos-page { padding: 40px 24px 16px; }
      .reel-controls { padding: 0 24px; }
      .reel-track { padding: 0 24px; }
      .reel-card { flex-basis: 90%; min-width: 0; }
      footer.tail { padding: 20px 24px; flex-direction: column; align-items: flex-start; gap: 12px; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0s !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0s !important;
      }
      .ticker-track {
        animation: ticker-scroll 28s linear infinite !important;
      }
      .reel-track { scroll-behavior: auto; }
    }
  </style>
</head>
<body>

  <!-- Live Wire ticker -->
  <div class="ticker">
    <div class="ticker-label">
      <span class="pulse"></span>
      <span>Live Wire</span>
    </div>
    <div class="ticker-stats" aria-label="Live channel statistics">
      <div class="ticker-track">
        <div class="stat">Videos <span class="v" data-stat="videos">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Subscribers <span class="v" data-stat="subs">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Total Views <span class="v" data-stat="views">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Top Episode <span class="v" data-stat="top">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Newest <span class="v" data-stat="newest">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat" aria-hidden="true">Videos <span class="v" data-stat="videos">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Subscribers <span class="v" data-stat="subs">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Total Views <span class="v" data-stat="views">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Top Episode <span class="v" data-stat="top">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Newest <span class="v" data-stat="newest">—</span><span class="sep">·</span></div>
      </div>
    </div>
  </div>

  <header class="top">
    <a href="/" class="home-link" aria-label="Boardroom Wire — home">
      BOARDROOM<span class="wire">WIRE</span>
    </a>
  </header>

  <main class="videos-page">
    <p class="page-eyebrow">Videos</p>
    <h1 class="page-heading">The <span class="accent">Reel.</span></h1>
    <p class="page-sub">Latest analysis from the channel — strategic breakdowns of business and technology, refreshed live from YouTube.</p>
  </main>

  <section class="reel" id="reel">
    <div class="reel-controls">
      <button type="button" class="reel-btn" id="reel-prev" aria-label="Previous">
        <svg viewBox="0 0 24 24"><path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
      </button>
      <button type="button" class="reel-btn" id="reel-next" aria-label="Next">
        <svg viewBox="0 0 24 24"><path d="M10 6 8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </button>
    </div>
    <div class="reel-track-wrap">
      <div class="reel-track" id="reel-track" role="list" aria-label="Latest videos">
        <!-- cards inserted by JS -->
      </div>
    </div>
  </section>

  <footer class="tail">
    <span>© 2026 Boardroom Wire</span>
    <a href="/">← Home</a>
  </footer>

  <script>
    import { fetchChannelData, fmt, daysAgo } from '../lib/youtube';

    const setStat = (name: string, value: string) => {
      document.querySelectorAll(`[data-stat="${name}"]`).forEach((el) => {
        el.textContent = value;
      });
    };

    const track = document.getElementById('reel-track')!;

    function renderReelPlaceholders(n = 6) {
      track.innerHTML = '';
      for (let i = 0; i < n; i++) {
        const card = document.createElement('div');
        card.className = 'reel-card placeholder';
        card.setAttribute('role', 'listitem');
        card.innerHTML = `<div class="thumb"></div><div class="meta"><h3>Episode ${i + 1}</h3></div>`;
        track.appendChild(card);
      }
    }

    function renderReelVideos(videos: Array<{ id: string; title: string; thumbnail: string }>) {
      track.innerHTML = '';
      for (const v of videos) {
        const a = document.createElement('a');
        a.className = 'reel-card';
        a.href = `https://www.youtube.com/watch?v=${v.id}`;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.setAttribute('role', 'listitem');
        a.setAttribute('aria-label', `Watch: ${v.title}`);
        a.innerHTML = `
          <div class="thumb">
            <img src="${v.thumbnail}" alt="" loading="lazy" />
            <div class="play"><span><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></span></div>
          </div>
          <div class="meta"><h3>${v.title}</h3></div>
        `;
        track.appendChild(a);
      }
    }

    async function hydrate() {
      const data = await fetchChannelData();
      if (!data) {
        renderReelPlaceholders();
        return;
      }
      setStat('videos', fmt(data.videos));
      setStat('subs',   fmt(data.subs));
      setStat('views',  fmt(data.views));
      setStat('top',    data.topVideo ? `${fmt(data.topVideo.views)} views` : '—');
      setStat('newest', data.newest ? daysAgo(data.newest.publishedAt) : '—');

      if (data.reel.length > 0) renderReelVideos(data.reel);
      else renderReelPlaceholders();
    }

    function setupReelControls() {
      const cardWidth = () => {
        const card = track.querySelector('.reel-card');
        if (!card) return 0;
        const styles = getComputedStyle(track);
        const gap = parseFloat(styles.gap) || 0;
        return card.getBoundingClientRect().width + gap;
      };

      document.getElementById('reel-prev')!.addEventListener('click', () => {
        track.scrollBy({ left: -cardWidth(), behavior: 'smooth' });
      });
      document.getElementById('reel-next')!.addEventListener('click', () => {
        track.scrollBy({ left: cardWidth(), behavior: 'smooth' });
      });

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      let paused = false;
      const reelSection = document.getElementById('reel')!;
      reelSection.addEventListener('mouseenter', () => { paused = true; });
      reelSection.addEventListener('mouseleave', () => { paused = false; });
      reelSection.addEventListener('focusin',  () => { paused = true; });
      reelSection.addEventListener('focusout', () => { paused = false; });

      setInterval(() => {
        if (paused) return;
        const w = cardWidth();
        if (!w) return;
        const max = track.scrollWidth - track.clientWidth - 4;
        if (track.scrollLeft >= max) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: w, behavior: 'smooth' });
        }
      }, 5000);
    }

    hydrate().then(setupReelControls);
    setInterval(hydrate, 5 * 60_000);
  </script>
</body>
</html>
