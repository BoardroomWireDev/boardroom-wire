---
// Videos page — same ticker / wordmark / footer shell as about.astro, with
// the YouTube reel carousel as the body. Hydrated from src/lib/youtube.ts.
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Videos · Boardroom Wire</title>
  <meta name="description" content="Latest video analysis from Boardroom Wire — strategic breakdowns of business and technology, refreshed live from the YouTube channel." />
  <link rel="icon" type="image/png" href="/logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

  <style>
    :root {
      --black:       #000000;
      --black-soft:  #0A0A0A;
      --line:        #1A1A1A;
      --white:       #F5F1E5;
      --white-dim:   #888173;
      --gold:        #D4AF37;
      --gold-bright: #F2CB52;
      --amber:        #FFB347;
      --amber-bright: #FFC97A;
      --amber-glow:   rgba(255, 179, 71, 0.4);
      --display: 'Inter', system-ui, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--black);
      color: var(--white);
      font-family: var(--display);
      overflow-x: hidden;
      min-height: 100vh;
    }

    body::before {
      content: "";
      position: fixed; inset: 0;
      pointer-events: none;
      z-index: 1000;
      opacity: 0.04;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.6'/%3E%3C/svg%3E");
    }

    /* ============ TICKER ============ */
    .ticker {
      display: flex;
      align-items: stretch;
      height: 54px;
      border-bottom: 1px solid var(--line);
      background: var(--black);
      position: relative;
      z-index: 10;
    }
    .ticker-label {
      background: var(--gold);
      color: var(--black);
      font-family: var(--display);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.24em;
      padding: 0 22px;
      display: flex;
      align-items: center;
      gap: 12px;
      text-transform: uppercase;
      box-shadow: 0 0 14px var(--amber-glow);
    }
    .ticker-label .pulse {
      width: 9px; height: 9px;
      background: #FF3B30;
      border-radius: 50%;
      box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7);
      filter: drop-shadow(0 0 4px rgba(255, 59, 48, 0.55));
      animation: pulse-red 1.4s ease-in-out infinite;
    }
    @keyframes pulse-red {
      0%   { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7); opacity: 1; }
      70%  { box-shadow: 0 0 0 10px rgba(255, 59, 48, 0); opacity: 0.85; }
      100% { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0); opacity: 1; }
    }
    .ticker-stats {
      flex: 1;
      overflow: hidden;
      position: relative;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
              mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
    }
    .ticker-track {
      display: flex;
      align-items: center;
      gap: 56px;
      height: 100%;
      width: max-content;
      padding-left: 32px;
      animation: ticker-scroll 28s linear infinite;
    }
    .ticker:hover .ticker-track,
    .ticker:focus-within .ticker-track {
      animation-play-state: paused;
    }
    @keyframes ticker-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .stat {
      font-family: var(--display);
      font-size: 13px;
      letter-spacing: 0.18em;
      color: var(--white-dim);
      text-transform: uppercase;
      font-weight: 500;
      display: flex;
      align-items: baseline;
      gap: 12px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .stat .v {
      color: var(--white);
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .stat .sep {
      color: var(--line);
      margin-left: 56px;
    }

    /* ============ HEADER ============ */
    header.top {
      padding: 28px 40px 0;
      position: relative;
      z-index: 5;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 24px;
    }
    .home-link {
      font-family: var(--display);
      font-weight: 900;
      font-size: 22px;
      letter-spacing: 0.02em;
      line-height: 1;
      color: var(--white);
      text-decoration: none;
      user-select: none;
    }
    .home-link .wire { color: var(--gold-bright); }
    .home-link:hover .wire { color: var(--gold); }
    /* Page label — sits inline with the home-link, no big page heading. */
    .page-label {
      font-family: var(--display);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--amber-bright);
      text-shadow: 0 0 12px rgba(255, 179, 71, 0.5);
    }

    /* CRT phosphor atmosphere — same overlay as /about/. */
    .page-fx {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background:
        radial-gradient(circle at 0% 0%,   rgba(255, 179, 71, 0.14), transparent 35%),
        radial-gradient(circle at 100% 0%, rgba(255, 179, 71, 0.10), transparent 35%),
        radial-gradient(circle at 0% 100%, rgba(255, 179, 71, 0.10), transparent 35%),
        radial-gradient(circle at 100% 100%, rgba(255, 179, 71, 0.14), transparent 35%),
        repeating-linear-gradient(
          to bottom,
          rgba(255, 179, 71, 0.035) 0,
          rgba(255, 179, 71, 0.035) 1px,
          transparent 1px,
          transparent 4px
        );
    }

    /* ============ POPULAR — static top 5 by view count ============ */
    section.popular {
      max-width: 1280px;
      margin: 0 auto;
      padding: 40px 24px 0;
      position: relative;
      z-index: 5;
    }
    .popular-label {
      font-family: var(--display);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--amber-bright);
      text-shadow: 0 0 12px rgba(255, 179, 71, 0.5);
      margin-bottom: 18px;
    }
    .popular-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 18px;
    }
    /* In a grid the .reel-card's flex sizing is moot — but the rest of the
       card styling (flex column inside, hover lift, thumbnail border etc.)
       still applies. */
    :global(.popular-grid .reel-card) {
      flex: 1 1 auto;
    }
    /* Show view counts only on the popular row — added via .pop modifier on
       the rendered card. */
    :global(.reel-card .views) {
      display: none;
    }
    :global(.reel-card.pop .views) {
      display: block;
      font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.08em;
      color: var(--amber);
      margin-top: 4px;
    }

    /* ============ REEL — two-row counter-scrolling marquee ============ */
    section.reel {
      padding: 32px 0 80px;
      position: relative;
      z-index: 5;
    }
    .reel-row {
      overflow: hidden;
      position: relative;
      margin-bottom: 22px;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 80px, #000 calc(100% - 80px), transparent 100%);
              mask-image: linear-gradient(90deg, transparent 0, #000 80px, #000 calc(100% - 80px), transparent 100%);
    }
    .reel-row:last-child { margin-bottom: 0; }
    .reel-track {
      display: flex;
      gap: 16px;
      width: max-content;
      padding-left: 24px;
      animation: reel-scroll 70s linear infinite;
      will-change: transform;
    }
    .reel-row.reverse .reel-track {
      animation-direction: reverse;
    }
    .reel-row:hover .reel-track,
    .reel-row:focus-within .reel-track {
      animation-play-state: paused;
    }
    @keyframes reel-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    /* .reel-card and its descendants are injected via JS (track.innerHTML =
       ...), so Astro's per-component scope attribute (data-astro-cid-...) is
       never on them. Wrap rules in :global() so they apply to the injected
       DOM. Same trick we used for the globe tooltip. */
    :global(.reel-card) {
      flex: 0 0 clamp(210px, 12vw, 300px);
      /* min-width: 0 defeats the default `min-width: auto` on flex items —
         without it, title min-content forces each card to bloat. */
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
      text-decoration: none;
      color: #F5F1E5;
      transition: transform 0.25s ease;
    }
    :global(.reel-card:hover) {
      transform: translateY(-4px);
    }
    /* Title above the thumbnail — 2-line clamp so longer titles still read. */
    :global(.reel-card .meta) {
      padding: 0 2px;
      min-height: 36px;
      min-width: 0;
    }
    :global(.reel-card .meta h3) {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 13px;
      font-weight: 500;
      line-height: 1.35;
      letter-spacing: -0.005em;
      color: #F5F1E5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin: 0;
    }
    :global(.reel-card:hover .meta h3) {
      color: #FFC97A;
    }
    :global(.reel-card .thumb) {
      position: relative;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: #0A0A0A;
      border: 1px solid #1A1A1A;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    :global(.reel-card:hover .thumb) {
      border-color: #FFB347;
      box-shadow: 0 0 16px rgba(255, 179, 71, 0.3);
    }
    :global(.reel-card .thumb img) {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.5s ease;
    }
    :global(.reel-card:hover .thumb img) { transform: scale(1.06); }
    :global(.reel-card.placeholder .thumb) {
      background: linear-gradient(135deg, #0a0a0a, #1a1a1a 50%, #0a0a0a);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    :global(.reel-card.placeholder .thumb::before) {
      content: "";
      width: 40px; height: 40px;
      border: 1px solid #1A1A1A;
      border-radius: 50%;
      background: rgba(212, 175, 55, 0.04);
    }

    /* ============ FOOTER ============ */
    footer.tail {
      border-top: 1px solid var(--line);
      padding: 28px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      font-family: var(--display);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white-dim);
    }
    footer.tail a {
      color: inherit;
      text-decoration: none;
      transition: color 0.18s;
    }
    footer.tail a:hover { color: var(--gold-bright); }

    @media (max-width: 720px) {
      header.top { padding: 20px 24px 0; }
      .home-link { font-size: 18px; }
      .ticker { height: 46px; }
      .ticker-track { gap: 36px; padding-left: 20px; }
      .stat { font-size: 11px; letter-spacing: 0.12em; gap: 8px; }
      .stat .sep { margin-left: 36px; }
      .ticker-label { font-size: 11px; padding: 0 14px; gap: 8px; }
      .ticker-label .pulse { width: 8px; height: 8px; }
      main.videos-page { padding: 40px 24px 16px; }
      .reel-row { margin-bottom: 18px; }
      .reel-track { padding-left: 16px; gap: 12px; }
      :global(.reel-card) { flex-basis: clamp(200px, 60vw, 280px); }
      section.popular { padding: 28px 18px 0; }
      .popular-grid { grid-template-columns: repeat(3, 1fr); gap: 10px; }
    }
    @media (max-width: 540px) {
      .popular-grid { grid-template-columns: repeat(2, 1fr); }
      footer.tail { padding: 20px 24px; flex-direction: column; align-items: flex-start; gap: 12px; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0s !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0s !important;
      }
      /* Brand-critical motion exempted from reduced-motion (same call as the
         ticker on home + about). Set duration + iteration-count only so the
         per-row animation-direction (.reel-row.reverse) is preserved. */
      .ticker-track {
        animation: ticker-scroll 28s linear infinite !important;
      }
      .reel-track {
        animation-duration: 70s !important;
        animation-iteration-count: infinite !important;
      }
    }
  </style>
</head>
<body>

  <!-- CRT phosphor atmosphere overlay (matches /about/) -->
  <div class="page-fx" aria-hidden="true"></div>

  <!-- Live Wire ticker -->
  <div class="ticker">
    <div class="ticker-label">
      <span class="pulse"></span>
      <span>Live Wire</span>
    </div>
    <div class="ticker-stats" aria-label="Live channel statistics">
      <div class="ticker-track">
        <div class="stat">Videos <span class="v" data-stat="videos">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Subscribers <span class="v" data-stat="subs">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Total Views <span class="v" data-stat="views">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Top Episode <span class="v" data-stat="top">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Newest <span class="v" data-stat="newest">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat" aria-hidden="true">Videos <span class="v" data-stat="videos">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Subscribers <span class="v" data-stat="subs">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Total Views <span class="v" data-stat="views">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Top Episode <span class="v" data-stat="top">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Newest <span class="v" data-stat="newest">—</span><span class="sep">·</span></div>
      </div>
    </div>
  </div>

  <header class="top">
    <a href="/" class="home-link" aria-label="Boardroom Wire — home">
      BOARDROOM<span class="wire">WIRE</span>
    </a>
    <span class="page-label">Videos</span>
  </header>

  <section class="popular" aria-label="Most popular videos">
    <p class="popular-label">Most Popular</p>
    <div class="popular-grid" id="popular-grid" role="list">
      <!-- top 5 cards inserted by JS -->
    </div>
  </section>

  <section class="reel" id="reel">
    <div class="reel-row" aria-label="Latest videos, top row">
      <div class="reel-track" id="reel-track-a" role="list">
        <!-- cards inserted by JS, duplicated for seamless marquee loop -->
      </div>
    </div>
    <div class="reel-row reverse" aria-label="Latest videos, bottom row">
      <div class="reel-track" id="reel-track-b" role="list">
        <!-- cards inserted by JS, duplicated for seamless marquee loop -->
      </div>
    </div>
  </section>

  <footer class="tail">
    <span>© 2026 Boardroom Wire</span>
    <a href="/">← Home</a>
  </footer>

  <script>
    import { fetchChannelData, fmt, daysAgo } from '../lib/youtube';

    const setStat = (name: string, value: string) => {
      document.querySelectorAll(`[data-stat="${name}"]`).forEach((el) => {
        el.textContent = value;
      });
    };

    const trackA = document.getElementById('reel-track-a')!;
    const trackB = document.getElementById('reel-track-b')!;
    const popularGrid = document.getElementById('popular-grid')!;

    const escape = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    function renderRow(
      track: HTMLElement,
      videos: Array<{ id: string; title: string; thumbnail: string }>,
    ) {
      // Duplicate for seamless 0 → -50% loop. Mark the second set aria-hidden
      // so screen readers don't read every video twice.
      const set = (hidden: boolean) =>
        videos
          .map(
            (v) => `
              <a class="reel-card"
                 href="https://www.youtube.com/watch?v=${v.id}"
                 target="_blank" rel="noopener noreferrer"
                 ${hidden ? 'aria-hidden="true" tabindex="-1"' : 'role="listitem"'}
                 aria-label="Watch: ${escape(v.title)}">
                <div class="meta"><h3>${escape(v.title)}</h3></div>
                <div class="thumb">
                  <img src="${v.thumbnail}" alt="" loading="lazy" />
                </div>
              </a>`,
          )
          .join('');
      track.innerHTML = set(false) + set(true);
    }

    function renderRowPlaceholders(track: HTMLElement, n = 6) {
      const cards = Array.from({ length: n }, (_, i) =>
        `<div class="reel-card placeholder" role="listitem"><div class="meta"><h3>Episode ${i + 1}</h3></div><div class="thumb"></div></div>`,
      ).join('');
      track.innerHTML = cards + cards; // duplicate for seamless loop
    }

    function renderPopular(
      videos: Array<{ id: string; title: string; thumbnail: string; views: number }>,
    ) {
      popularGrid.innerHTML = videos
        .map(
          (v) => `
            <a class="reel-card pop"
               href="https://www.youtube.com/watch?v=${v.id}"
               target="_blank" rel="noopener noreferrer"
               role="listitem"
               aria-label="Watch: ${escape(v.title)} (${fmt(v.views)} views)">
              <div class="meta">
                <h3>${escape(v.title)}</h3>
                <span class="views">${fmt(v.views)} views</span>
              </div>
              <div class="thumb">
                <img src="${v.thumbnail}" alt="" loading="lazy" />
              </div>
            </a>`,
        )
        .join('');
    }

    function renderPopularPlaceholders() {
      popularGrid.innerHTML = Array.from({ length: 5 }, (_, i) =>
        `<div class="reel-card pop placeholder" role="listitem"><div class="meta"><h3>Top ${i + 1}</h3><span class="views">— views</span></div><div class="thumb"></div></div>`,
      ).join('');
    }

    async function hydrate() {
      const data = await fetchChannelData();
      if (!data) {
        renderPopularPlaceholders();
        renderRowPlaceholders(trackA);
        renderRowPlaceholders(trackB);
        return;
      }
      setStat('videos', fmt(data.videos));
      setStat('subs',   fmt(data.subs));
      setStat('views',  fmt(data.views));
      setStat('top',    data.topVideo ? `${fmt(data.topVideo.views)} views` : '—');
      setStat('newest', data.newest ? daysAgo(data.newest.publishedAt) : '—');

      if (data.topVideos && data.topVideos.length > 0) {
        renderPopular(data.topVideos);
      } else {
        renderPopularPlaceholders();
      }

      if (data.reel.length > 0) {
        const half = Math.ceil(data.reel.length / 2);
        const topRow = data.reel.slice(0, half);
        const bottomRow = data.reel.slice(half);
        renderRow(trackA, topRow);
        renderRow(trackB, bottomRow.length > 0 ? bottomRow : topRow);
      } else {
        renderRowPlaceholders(trackA);
        renderRowPlaceholders(trackB);
      }
    }

    hydrate();
    setInterval(hydrate, 5 * 60_000);
  </script>
</body>
</html>
