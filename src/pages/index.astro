---
// Homepage — adapted from boardroom-wire-home.html (TBPN-inspired baseline).
// YouTube data and channel ID live in src/lib/youtube.ts; this page just
// imports fetchChannelData() from there in the body script.
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Boardroom Wire</title>
  <meta name="description" content="Forensic analysis of the companies shaping the future." />
  <link rel="icon" type="image/png" href="/logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

  <style>
    :root {
      --black:       #000000;
      --black-soft:  #0A0A0A;
      --line:        #1A1A1A;

      --white:       #F5F1E5;
      --white-dim:   #888173;

      --gold:        #D4AF37;
      --gold-bright: #F2CB52;

      /* Phosphor amber — for emissive elements (pulsing, glowing, on-air).
         Static UI stays on --gold; anything that emits light uses --amber. */
      --amber:        #FFB347;
      --amber-bright: #FFC97A;
      --amber-glow:   rgba(255, 179, 71, 0.4);

      --display: 'Inter', system-ui, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--black);
      color: var(--white);
      font-family: var(--display);
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* Subtle film-grain overlay */
    body::before {
      content: "";
      position: fixed; inset: 0;
      pointer-events: none;
      z-index: 1000;
      opacity: 0.04;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.6'/%3E%3C/svg%3E");
    }

    /* ============ TICKER ============ */
    .ticker {
      display: flex;
      align-items: stretch;
      height: 54px;
      border-bottom: 1px solid var(--line);
      background: var(--black);
      position: relative;
      z-index: 10;
    }
    .ticker-label {
      background: var(--gold);
      color: var(--black);
      font-family: var(--display);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.24em;
      padding: 0 22px;
      display: flex;
      align-items: center;
      gap: 12px;
      text-transform: uppercase;
      /* Faint amber halo so the gold chip reads as "lit" alongside the
         globe's bloom — tiny, not glowy. */
      box-shadow: 0 0 14px var(--amber-glow);
    }
    .ticker-label .pulse {
      width: 9px; height: 9px;
      background: #FF3B30;
      border-radius: 50%;
      box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7);
      filter: drop-shadow(0 0 4px rgba(255, 59, 48, 0.55));
      animation: pulse-red 1.4s ease-in-out infinite;
    }
    @keyframes pulse-red {
      0%   { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7); opacity: 1; }
      70%  { box-shadow: 0 0 0 10px rgba(255, 59, 48, 0); opacity: 0.85; }
      100% { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0); opacity: 1; }
    }
    .ticker-stats {
      flex: 1;
      overflow: hidden;
      position: relative;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
              mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
    }
    .ticker-track {
      display: flex;
      align-items: center;
      gap: 56px;
      height: 100%;
      width: max-content;
      padding-left: 32px;
      animation: ticker-scroll 28s linear infinite;
    }
    .ticker:hover .ticker-track,
    .ticker:focus-within .ticker-track {
      animation-play-state: paused;
    }
    @keyframes ticker-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .stat {
      font-family: var(--display);
      font-size: 13px;
      letter-spacing: 0.18em;
      color: var(--white-dim);
      text-transform: uppercase;
      font-weight: 500;
      display: flex;
      align-items: baseline;
      gap: 12px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .stat .v {
      color: var(--white);
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .stat.live .v.on  { color: var(--gold-bright); }
    .stat.live .v.off { color: var(--white-dim); }
    .stat .sep {
      color: var(--line);
      margin-left: 56px;
    }

    /* ============ HERO ============ */
    main.hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 56px 24px 80px;
      min-height: calc(100vh - 54px - 80px);
      position: relative;
      z-index: 5;
    }
    .wordmark {
      font-family: var(--display);
      font-weight: 900;
      font-size: clamp(48px, 9vw, 112px);
      line-height: 0.95;
      letter-spacing: -0.02em;
      color: var(--white);
      margin-bottom: 32px;
      user-select: none;
      opacity: 0;
      animation: fadeUp 0.9s ease-out 0.1s forwards;
    }
    .wordmark .wire { color: var(--gold-bright); }
    .globe-wrap {
      position: relative;
      width: min(1200px, 95vw);
      aspect-ratio: 1 / 1;
      /* Pull the wrapper up so the visible sphere sits just below the
         favicon row. The canvas's empty top portion is transparent. */
      margin-top: clamp(-120px, -5vw, -30px);
      margin-bottom: clamp(-110px, -4vw, -20px);
      opacity: 0;
      animation: fadeIn 1.4s ease-out 0.45s forwards;
    }
    #globe {
      width: 100%;
      height: 100%;
      cursor: grab;
    }
    #globe:active { cursor: grabbing; }

    /* ====== City tooltip (.pointLabel) ======
       Globe.gl injects the tooltip HTML dynamically into a .scene-tooltip
       wrapper outside of Astro's component scope, so these rules need
       :global() to match the injected DOM. */
    :global(.scene-tooltip) {
      pointer-events: none;
    }
    :global(.globe-tooltip) {
      font-family: 'Inter', system-ui, sans-serif;
      background: rgba(10, 10, 10, 0.95);
      border: 1px solid rgba(255, 179, 71, 0.45);
      border-radius: 4px;
      padding: 14px 18px;
      max-width: 280px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6), 0 0 12px rgba(255, 179, 71, 0.4);
    }
    :global(.globe-tooltip .gt-row) {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 8px;
    }
    :global(.globe-tooltip .gt-code) {
      font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.12em;
      color: #F2CB52;
    }
    :global(.globe-tooltip .gt-time) {
      font-family: ui-monospace, 'SF Mono', Menlo, monospace;
      font-size: 12px;
      font-weight: 500;
      color: #888173;
      font-variant-numeric: tabular-nums;
    }
    :global(.globe-tooltip .gt-name) {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #F5F1E5;
      margin-bottom: 4px;
    }
    :global(.globe-tooltip .gt-role) {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #FFB347;
      margin-bottom: 10px;
    }
    :global(.globe-tooltip .gt-thesis) {
      font-size: 13px;
      font-weight: 400;
      line-height: 1.45;
      color: #888173;
      font-style: italic;
    }

    /* Click pulse — gold ring blooms outward from the globe center on every
       city click. Element is spawned by JS in onPointClick and removed after
       its keyframe completes. */
    .globe-pulse {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 0;
      height: 0;
      margin: 0;
      border: 2px solid var(--amber);
      border-radius: 50%;
      pointer-events: none;
      box-shadow: 0 0 24px var(--amber-glow), inset 0 0 12px var(--amber-glow);
      animation: globe-pulse-out 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }
    @keyframes globe-pulse-out {
      0%   { width: 0;    height: 0;    margin: 0;            opacity: 0.7; border-width: 2px; }
      100% { width: 110%; height: 110%; margin: -55% 0 0 -55%; opacity: 0;   border-width: 0.5px; }
    }

    /* Brand tagline — sits inline in the find-row, all caps. */
    .tagline-row {
      font-family: var(--display);
      font-weight: 600;
      font-size: clamp(14px, 1.4vw, 18px);
      line-height: 1.3;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--white);
      white-space: nowrap;
    }
    .tagline-row em {
      font-style: normal;
      font-weight: 700;
      color: var(--gold-bright);
      text-shadow: 0 0 14px rgba(255, 179, 71, 0.55);
    }

    /* CRT phosphor atmosphere overlay — same as /about/. Fixed corner radial
       amber glows + faint horizontal scanline pattern. Sits behind content. */
    .page-fx {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background:
        radial-gradient(circle at 0% 0%,   rgba(255, 179, 71, 0.14), transparent 35%),
        radial-gradient(circle at 100% 0%, rgba(255, 179, 71, 0.10), transparent 35%),
        radial-gradient(circle at 0% 100%, rgba(255, 179, 71, 0.10), transparent 35%),
        radial-gradient(circle at 100% 100%, rgba(255, 179, 71, 0.14), transparent 35%),
        repeating-linear-gradient(
          to bottom,
          rgba(255, 179, 71, 0.035) 0,
          rgba(255, 179, 71, 0.035) 1px,
          transparent 1px,
          transparent 4px
        );
    }

    /* Single row directly under the wordmark — TBPN-style:
       "Find Boardroom Wire" label on the left, social icons + More Info on the right. */
    .find-row {
      width: 100%;
      max-width: 1080px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 36px;
      margin-bottom: 8px;
      opacity: 0;
      animation: fadeUp 0.9s ease-out 0.3s forwards;
      /* Above the globe canvas — the negative-margin pull on .globe-wrap
         makes the canvas overlap this row, and we need the favicon clicks
         to land on the row, not on the (transparent) canvas above them. */
      position: relative;
      z-index: 2;
    }
    .find-row-right {
      display: flex;
      align-items: center;
      gap: 28px;
    }
    .find-us-label {
      font-family: var(--display);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.28em;
      color: var(--white-dim);
      text-transform: uppercase;
    }
    .socials {
      display: flex;
      gap: 22px;
      align-items: center;
    }
    .socials a {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      color: var(--white);
      transition: all 0.2s;
      text-decoration: none;
    }
    .socials a:hover {
      color: var(--gold-bright);
      transform: translateY(-2px);
    }
    .socials svg {
      width: 20px;
      height: 20px;
      fill: currentColor;
    }
    .more-info {
      display: inline-block;
      font-family: var(--display);
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 0.24em;
      color: var(--black);
      text-transform: uppercase;
      text-decoration: none;
      background: var(--gold-bright);
      border: none;
      padding: 18px 36px;
      transition: all 0.2s;
      white-space: nowrap;
      box-shadow: 0 4px 0 0 var(--gold);
    }
    .more-info:hover {
      background: var(--gold);
      box-shadow: 0 6px 0 0 #b8932e, 0 0 24px var(--amber-glow);
      transform: translateY(-2px);
    }
    .more-info:active {
      transform: translateY(2px);
      box-shadow: 0 2px 0 0 var(--gold);
    }

    /* Footer */
    footer.tail {
      border-top: 1px solid var(--line);
      padding: 28px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      font-family: var(--display);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white-dim);
    }
    footer.tail a {
      color: inherit;
      text-decoration: none;
      transition: color 0.18s;
    }
    footer.tail a:hover { color: var(--gold-bright); }

    /* Animations */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* Responsive */
    @media (max-width: 720px) {
      .ticker { height: 46px; }
      .ticker-track { gap: 36px; padding-left: 20px; }
      .stat { font-size: 11px; letter-spacing: 0.12em; gap: 8px; }
      .stat .sep { margin-left: 36px; }
      .ticker-label { font-size: 11px; padding: 0 14px; gap: 8px; }
      .ticker-label .pulse { width: 8px; height: 8px; }
      main.hero { padding: 40px 24px 64px; }
      .wordmark { font-size: clamp(40px, 12vw, 64px); margin-bottom: 24px; }
      .find-row {
        flex-direction: column;
        gap: 20px;
        margin-bottom: 12px;
      }
      .find-row-right {
        flex-direction: column;
        gap: 18px;
      }
      .socials { gap: 20px; }
      footer.tail { padding: 20px 24px; flex-direction: column; align-items: flex-start; gap: 12px; }
    }

    @media (prefers-reduced-motion: reduce) {
      /* Heavy motion (globe rotation, carousel autoplay, hero fades) respects
         the preference. The ticker keeps animating — it's a horizontal text
         crawl, not the kind of vestibular trigger this preference targets. */
      *, *::before, *::after {
        animation-duration: 0s !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0s !important;
      }
      .ticker-track {
        animation: ticker-scroll 28s linear infinite !important;
      }
    }
  </style>
</head>
<body>

  <!-- CRT phosphor atmosphere overlay -->
  <div class="page-fx" aria-hidden="true"></div>

  <!-- Live Wire ticker -->
  <div class="ticker">
    <div class="ticker-label">
      <span class="pulse"></span>
      <span>Live Wire</span>
    </div>
    <div class="ticker-stats" aria-label="Live channel statistics">
      <div class="ticker-track">
        <div class="stat">Videos <span class="v" data-stat="videos">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Subscribers <span class="v" data-stat="subs">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Total Views <span class="v" data-stat="views">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Top Episode <span class="v" data-stat="top">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Newest <span class="v" data-stat="newest">—</span><span class="sep" aria-hidden="true">·</span></div>
        <!-- Duplicate set for seamless marquee loop -->
        <div class="stat" aria-hidden="true">Videos <span class="v" data-stat="videos">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Subscribers <span class="v" data-stat="subs">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Total Views <span class="v" data-stat="views">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Top Episode <span class="v" data-stat="top">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Newest <span class="v" data-stat="newest">—</span><span class="sep">·</span></div>
      </div>
    </div>
  </div>

  <!-- Hero -->
  <main class="hero">
    <div class="wordmark" aria-label="Boardroom Wire">
      BOARDROOM<span class="wire">WIRE</span>
    </div>

    <div class="find-row">
      <p class="tagline-row">Strategic Analysis. <em>Business &amp; Technology.</em></p>
      <div class="find-row-right">
        <div class="socials">
          <a href="https://x.com/BoardroomWire" target="_blank" rel="noopener" title="X" aria-label="X">
            <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.youtube.com/@BoardroomWire" target="_blank" rel="noopener" title="YouTube" aria-label="YouTube">
            <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://substack.com/@boardroom1" target="_blank" rel="noopener" title="Substack" aria-label="Substack">
            <svg viewBox="0 0 24 24"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
          </a>
        </div>
        <a href="/about/" class="more-info">About</a>
        <a href="/videos/" class="more-info">Videos</a>
      </div>
    </div>

    <div class="globe-wrap" id="globe-wrap">
      <div id="globe"></div>
    </div>
  </main>

  <footer class="tail">
    <span>© 2026 Boardroom Wire</span>
    <a href="/about/">About</a>
  </footer>

  <!-- YouTube live data — both ticker and reel feed off one cached fetch -->
  <script>
    import { fetchChannelData, fmt, daysAgo } from '../lib/youtube';

    const setStat = (name: string, value: string) => {
      document.querySelectorAll(`[data-stat="${name}"]`).forEach((el) => {
        el.textContent = value;
      });
    };

    async function hydrate() {
      const data = await fetchChannelData();
      if (!data) return; // ticker keeps em-dashes
      setStat('videos', fmt(data.videos));
      setStat('subs',   fmt(data.subs));
      setStat('views',  fmt(data.views));
      setStat('top',    data.topVideo ? `${fmt(data.topVideo.views)} views` : '—');
      setStat('newest', data.newest ? daysAgo(data.newest.publishedAt) : '—');
    }
    hydrate();
    // Refresh every 5 minutes — picks up cached or fresh data automatically
    setInterval(hydrate, 5 * 60_000);
  </script>

  <!-- globe.gl hero globe — capital-markets cities + arcs + rings + click-to-emit -->
  <script>
    import Globe from 'globe.gl';
    import * as THREE from 'three';
    import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';

    // Phosphor amber for emissive layers (points, arcs, rings) — blooms cleanly
    // toward warm cream-white. Pure gold (#D4AF37) bleeds toward yellow under
    // bloom; static UI stays gold, anything that emits light goes amber.
    const AMBER = '#FFB347';
    const AMBER_BRIGHT = '#FFC97A';
    const FLIGHT_TIME = 1000;
    const RINGS_MAX_R = 5;
    const RING_PROPAGATION_SPEED = 5;
    const AMBIENT_INTERVAL = 2500;
    const MAX_AMBIENT_ARCS = 6;

    // Strategic global capital-markets / tech-infrastructure centers.
    type City = {
      name: string;
      code: string;
      exchange: string;
      role: string;
      thesis: string;
      tz: string;
      lat: number;
      lng: number;
    };
    const cities: City[] = [
      { name: 'New York',      code: 'NYC', exchange: 'NYSE',   role: 'Capital flows',         thesis: 'Where the money decides what the future means.',         tz: 'America/New_York',    lat:  40.7128, lng:  -74.0060 },
      { name: 'San Francisco', code: 'SFO', exchange: 'Nasdaq', role: 'Compute & code',        thesis: 'Where the future gets coded — and overpriced.',          tz: 'America/Los_Angeles', lat:  37.7749, lng: -122.4194 },
      { name: 'Toronto',       code: 'YYZ', exchange: 'TSX',    role: 'Quiet AI capital',      thesis: 'Loud regulators, quieter founders.',                     tz: 'America/Toronto',     lat:  43.6532, lng:  -79.3832 },
      { name: 'São Paulo',     code: 'GRU', exchange: 'B3',     role: 'LatAm tech',            thesis: 'The southern hemisphere\'s only deep-tech bench.',        tz: 'America/Sao_Paulo',   lat: -23.5505, lng:  -46.6333 },
      { name: 'London',        code: 'LON', exchange: 'LSE',    role: 'Cross-border capital',  thesis: 'Where the LSE meets compute capex.',                     tz: 'Europe/London',       lat:  51.5074, lng:   -0.1278 },
      { name: 'Frankfurt',     code: 'FRA', exchange: 'FWB',    role: 'EU underwriting',       thesis: 'Europe\'s checkbook on AI infrastructure.',               tz: 'Europe/Berlin',       lat:  50.1109, lng:    8.6821 },
      { name: 'Zurich',        code: 'ZRH', exchange: 'SIX',    role: 'Old money',             thesis: 'Old wealth, new model weights.',                         tz: 'Europe/Zurich',       lat:  47.3769, lng:    8.5417 },
      { name: 'Dubai',         code: 'DXB', exchange: 'DFM',    role: 'Sovereign capital',     thesis: 'Sovereign-fund AI, accelerated.',                        tz: 'Asia/Dubai',          lat:  25.2048, lng:   55.2708 },
      { name: 'Mumbai',        code: 'BOM', exchange: 'NSE',    role: 'Talent factory',        thesis: 'Talent factory, balance-sheet pressure.',                tz: 'Asia/Kolkata',        lat:  19.0760, lng:   72.8777 },
      { name: 'Singapore',     code: 'SIN', exchange: 'SGX',    role: 'Switching center',      thesis: 'Asia\'s neutral switching center.',                       tz: 'Asia/Singapore',      lat:   1.3521, lng:  103.8198 },
      { name: 'Hong Kong',     code: 'HKG', exchange: 'HKEX',   role: 'East-West gate',        thesis: 'Where the East-West money still crosses.',               tz: 'Asia/Hong_Kong',      lat:  22.3193, lng:  114.1694 },
      { name: 'Shanghai',      code: 'PVG', exchange: 'SSE',    role: 'China capital',         thesis: 'China\'s AI capital choke point.',                        tz: 'Asia/Shanghai',       lat:  31.2304, lng:  121.4737 },
      { name: 'Seoul',         code: 'ICN', exchange: 'KRX',    role: 'Memory + foundry',      thesis: 'The memory + foundry stack of the AI economy.',          tz: 'Asia/Seoul',          lat:  37.5665, lng:  126.9780 },
      { name: 'Tokyo',         code: 'TYO', exchange: 'TSE',    role: 'AI capex bed',          thesis: 'SoftBank\'s home; AI capex test bed.',                    tz: 'Asia/Tokyo',          lat:  35.6762, lng:  139.6503 },
    ];

    const fmtLocalTime = (tz: string): string =>
      new Intl.DateTimeFormat('en-US', {
        hour: '2-digit',
        minute: '2-digit',
        hour12: false,
        timeZone: tz,
      }).format(new Date());

    const escapeHtml = (s: string): string =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    const renderTooltip = (c: City): string => `
      <div class="globe-tooltip">
        <div class="gt-row">
          <span class="gt-code">${escapeHtml(c.code)}</span>
          <span class="gt-time">${fmtLocalTime(c.tz)}</span>
        </div>
        <div class="gt-name">${escapeHtml(c.name)}</div>
        <div class="gt-role">${escapeHtml(c.exchange)} · ${escapeHtml(c.role)}</div>
        <div class="gt-thesis">${escapeHtml(c.thesis)}</div>
      </div>
    `;

    // Hex landmass on by default; ?hex=0 turns it off for the pure-abstract variant.
    const params = new URLSearchParams(window.location.search);
    const useHex = params.get('hex') !== '0';
    const wrap = document.getElementById('globe-wrap');

    const arcs: Array<{ startLat: number; startLng: number; endLat: number; endLng: number }> = [];
    const rings: Array<{ lat: number; lng: number }> = [];

    // Hover + active state for the city dots — drives both the visual point lift
    // and the tooltip selection. See refreshPointAccessors() below.
    let hoveredCity: City | null = null;
    let activeCity:  City | null = null;
    let activeTimeout: number | null = null;
    const isHighlit = (c: City) => c === hoveredCity || c === activeCity;

    const el = document.getElementById('globe')!;
    const size = el.clientWidth;

    const globe = new (Globe as any)(el)
      .width(size)
      .height(size)
      .backgroundColor('rgba(0,0,0,0)')
      .showAtmosphere(false)
      .globeImageUrl(null as any)
      .pointsData(cities)
      .pointLat('lat')
      .pointLng('lng')
      .pointColor(() => AMBER_BRIGHT)
      .pointAltitude((c: City) => isHighlit(c) ? 0.06 : 0.01)
      .pointRadius((c: City) => isHighlit(c) ? 0.55 : 0.4)
      .pointResolution(12)
      .pointLabel((c: City) => renderTooltip(c))
      .arcsData(arcs)
      .arcColor(() => AMBER)
      .arcDashLength(0.4)
      .arcDashGap(2)
      .arcDashAnimateTime(2000)
      .arcStroke(0.4)
      .arcsTransitionDuration(0)
      .ringsData(rings)
      .ringColor(() => (t: number) => `rgba(255, 179, 71, ${1 - t})`)
      .ringMaxRadius(RINGS_MAX_R)
      .ringPropagationSpeed(RING_PROPAGATION_SPEED)
      .ringRepeatPeriod((FLIGHT_TIME * RINGS_MAX_R) / RING_PROPAGATION_SPEED / 3);

    // Pure black sphere so the back of the globe doesn't show points/arcs through.
    const mat = globe.globeMaterial() as any;
    if (mat && mat.color && typeof mat.color.set === 'function') {
      mat.color.set('#000000');
    }

    // Auto-rotate. Reduced-motion intentionally NOT respected here — the globe
    // is the brand hero element, same treatment as the ticker marquee.
    const controls = (globe.controls() as any);
    if (controls) {
      controls.autoRotate = true;
      controls.autoRotateSpeed = 0.4;
      controls.enableZoom = false; // don't let scroll-zoom hijack page scroll
    }

    // Zoom the camera in slightly so the visible sphere fills more of the
    // canvas (default altitude 2.5 leaves ~17% empty padding at the top of
    // the canvas; 1.85 brings it down to ~9%, which combined with the
    // negative wrapper margin lands the sphere top near the favicon row).
    globe.pointOfView({ lat: 0, lng: 0, altitude: 1.85 });

    // ====== Luminescence layer ======
    // ACES filmic tone mapping crushes blacks and lifts highlights so the
    // bloom reads cinematic instead of like a CSS filter.
    const renderer = (globe.renderer() as any);
    if (renderer) {
      renderer.toneMapping = THREE.ACESFilmicToneMapping;
      renderer.toneMappingExposure = 1.0;
    }

    // Bloom pass — desktop only (bloom on mobile GPUs adds ~10-20ms/frame).
    const isMobile = window.matchMedia('(max-width: 720px)').matches;
    if (!isMobile) {
      const composer = (globe.postProcessingComposer() as any);
      if (composer) {
        // Half-resolution render target — visually identical for soft glow,
        // ~4x cheaper than full-screen.
        const w = window.innerWidth / 2;
        const h = window.innerHeight / 2;
        const bloomPass = new UnrealBloomPass(
          new THREE.Vector2(w, h),
          0.65, // strength — start conservative, dial up if too thin
          0.5,  // radius   — tighter glow first
          0.2,  // threshold — only the brightest pixels (point dots, arc heads) bloom
        );
        composer.addPass(bloomPass);
      }
    }

    // Additive blending on emissive layers — overlapping arcs/points brighten
    // instead of mixing, which is the "phosphor" core of the look. Identify
    // emissive meshes by their color (amber-bright) so we don't touch the
    // base sphere or hex landmass.
    const isAmberPoint = (color: any): boolean => {
      if (!color || typeof color.getHexString !== 'function') return false;
      const hex = color.getHexString().toLowerCase();
      return hex === 'ffc97a' || hex === 'ffb347';
    };
    queueMicrotask(() => {
      // Defer to next tick so globe.gl has finished initial scene population.
      globe.scene().traverse((obj: any) => {
        if (!obj.material) return;
        const mats = Array.isArray(obj.material) ? obj.material : [obj.material];
        for (const m of mats) {
          if (m && m.color && isAmberPoint(m.color)) {
            m.blending = THREE.AdditiveBlending;
            m.transparent = true;
            m.depthWrite = false;
          }
        }
      });
    });

    // Hex polygons — only when ?hex=1
    if (useHex) {
      fetch('https://unpkg.com/globe.gl/example/datasets/ne_110m_admin_0_countries.geojson')
        .then((r) => r.json())
        .then((geo) => {
          globe
            .hexPolygonsData(geo.features)
            .hexPolygonResolution(3)
            .hexPolygonMargin(0.3)
            .hexPolygonAltitude(0.005)
            // Lower opacity than the points so hex landmass stays under the
            // bloom threshold and reads as base layer, not a glowing layer.
            .hexPolygonColor(() => 'rgba(255, 179, 71, 0.35)');
        })
        .catch((err) => console.warn('[globe] hex polygons fetch failed:', err));
    }

    // Resize handling — keep canvas square to wrapper
    const onResize = () => {
      const s = el.clientWidth;
      globe.width(s).height(s);
    };
    window.addEventListener('resize', onResize);

    // ====== Click-to-emit: clicked city → arc to random other city → ring at destination ======
    const fireArc = (start: typeof cities[number], end: typeof cities[number]) => {
      const arc = {
        startLat: start.lat,
        startLng: start.lng,
        endLat: end.lat,
        endLng: end.lng,
      };
      arcs.push(arc);
      globe.arcsData([...arcs]);
      // Remove arc after full flight + dash trail clears
      setTimeout(() => {
        const i = arcs.indexOf(arc);
        if (i >= 0) arcs.splice(i, 1);
        globe.arcsData([...arcs]);
      }, FLIGHT_TIME * 2);

      // Emit ring at destination when arc lands
      setTimeout(() => {
        const ring = { lat: end.lat, lng: end.lng };
        rings.push(ring);
        globe.ringsData([...rings]);
        setTimeout(() => {
          const j = rings.indexOf(ring);
          if (j >= 0) rings.splice(j, 1);
          globe.ringsData([...rings]);
        }, (FLIGHT_TIME * RINGS_MAX_R) / RING_PROPAGATION_SPEED);
      }, FLIGHT_TIME);
    };

    function spawnGlobePulse() {
      if (!wrap) return;
      const pulse = document.createElement('div');
      pulse.className = 'globe-pulse';
      wrap.appendChild(pulse);
      setTimeout(() => pulse.remove(), 1500);
    }

    // Re-set the point-altitude/radius accessors so globe.gl re-evaluates per
    // city — this is what visually lifts the hovered/active dot.
    const refreshPointAccessors = () => {
      globe
        .pointAltitude((c: City) => isHighlit(c) ? 0.06 : 0.01)
        .pointRadius((c: City) => isHighlit(c) ? 0.55 : 0.4);
    };

    // Pause auto-rotate while the user is engaged with a tooltip — either
    // hovering a city or in the 2s active-after-click window. The slowly
    // rotating sphere otherwise carries the tooltip away while you're
    // reading it.
    const refreshRotation = () => {
      if (controls) {
        controls.autoRotate = !hoveredCity && !activeCity;
      }
    };

    globe.onPointHover((point: City | null) => {
      hoveredCity = point;
      refreshPointAccessors();
      refreshRotation();
    });

    globe.onPointClick((point: any) => {
      // Hold the clicked city in "active" state for 2s so the click feels
      // like a selection, not a bounce.
      activeCity = point as City;
      if (activeTimeout !== null) clearTimeout(activeTimeout);
      activeTimeout = window.setTimeout(() => {
        activeCity = null;
        refreshPointAccessors();
        refreshRotation();
      }, 2000);
      refreshPointAccessors();
      refreshRotation();

      let target = cities[Math.floor(Math.random() * cities.length)];
      // pick again if we landed on the source
      while (target === point && cities.length > 1) {
        target = cities[Math.floor(Math.random() * cities.length)];
      }
      fireArc(point as typeof cities[number], target);
      spawnGlobePulse();
    });

    // ====== Ambient activity — random arc every 2.5s, capped at 6 ======
    // Always runs (same rationale as the ticker: brand-critical motion).
    setInterval(() => {
      if (arcs.length >= MAX_AMBIENT_ARCS) return;
      const a = cities[Math.floor(Math.random() * cities.length)];
      let b = cities[Math.floor(Math.random() * cities.length)];
      while (b === a) b = cities[Math.floor(Math.random() * cities.length)];
      fireArc(a, b);
    }, AMBIENT_INTERVAL);
  </script>

</body>
</html>
