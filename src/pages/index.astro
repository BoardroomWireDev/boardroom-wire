---
// Homepage — adapted from boardroom-wire-home.html (TBPN-inspired baseline).
// YouTube data and channel ID live in src/lib/youtube.ts; this page just
// imports fetchChannelData() from there in the body script.
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Boardroom Wire</title>
  <meta name="description" content="Forensic analysis of the companies shaping the future." />
  <link rel="icon" type="image/png" href="/logo.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

  <style>
    :root {
      --black:       #000000;
      --black-soft:  #0A0A0A;
      --line:        #1A1A1A;

      --white:       #F5F1E5;
      --white-dim:   #888173;

      --gold:        #D4AF37;
      --gold-bright: #F2CB52;

      --display: 'Inter', system-ui, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: var(--black);
      color: var(--white);
      font-family: var(--display);
      overflow-x: hidden;
      min-height: 100vh;
    }

    /* Subtle film-grain overlay */
    body::before {
      content: "";
      position: fixed; inset: 0;
      pointer-events: none;
      z-index: 1000;
      opacity: 0.04;
      mix-blend-mode: overlay;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.6'/%3E%3C/svg%3E");
    }

    /* ============ TICKER ============ */
    .ticker {
      display: flex;
      align-items: stretch;
      height: 54px;
      border-bottom: 1px solid var(--line);
      background: var(--black);
      position: relative;
      z-index: 10;
    }
    .ticker-label {
      background: var(--gold);
      color: var(--black);
      font-family: var(--display);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.24em;
      padding: 0 22px;
      display: flex;
      align-items: center;
      gap: 12px;
      text-transform: uppercase;
    }
    .ticker-label .pulse {
      width: 9px; height: 9px;
      background: #FF3B30;
      border-radius: 50%;
      box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7);
      animation: pulse-red 1.4s ease-in-out infinite;
    }
    @keyframes pulse-red {
      0%   { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.7); opacity: 1; }
      70%  { box-shadow: 0 0 0 10px rgba(255, 59, 48, 0); opacity: 0.85; }
      100% { box-shadow: 0 0 0 0 rgba(255, 59, 48, 0); opacity: 1; }
    }
    .ticker-stats {
      flex: 1;
      overflow: hidden;
      position: relative;
      -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
              mask-image: linear-gradient(90deg, transparent 0, #000 40px, #000 calc(100% - 40px), transparent 100%);
    }
    .ticker-track {
      display: flex;
      align-items: center;
      gap: 56px;
      height: 100%;
      width: max-content;
      padding-left: 32px;
      animation: ticker-scroll 28s linear infinite;
    }
    .ticker:hover .ticker-track,
    .ticker:focus-within .ticker-track {
      animation-play-state: paused;
    }
    @keyframes ticker-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }
    .stat {
      font-family: var(--display);
      font-size: 13px;
      letter-spacing: 0.18em;
      color: var(--white-dim);
      text-transform: uppercase;
      font-weight: 500;
      display: flex;
      align-items: baseline;
      gap: 12px;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .stat .v {
      color: var(--white);
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    .stat.live .v.on  { color: var(--gold-bright); }
    .stat.live .v.off { color: var(--white-dim); }
    .stat .sep {
      color: var(--line);
      margin-left: 56px;
    }

    /* ============ HERO ============ */
    main.hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 56px 24px 80px;
      min-height: calc(100vh - 54px - 80px);
      position: relative;
      z-index: 5;
    }
    .wordmark {
      font-family: var(--display);
      font-weight: 900;
      font-size: clamp(48px, 9vw, 112px);
      line-height: 0.95;
      letter-spacing: -0.02em;
      color: var(--white);
      margin-bottom: 32px;
      user-select: none;
      opacity: 0;
      animation: fadeUp 0.9s ease-out 0.1s forwards;
    }
    .wordmark .wire { color: var(--gold-bright); }
    .globe-wrap {
      position: relative;
      width: min(480px, 75vw);
      aspect-ratio: 1 / 1;
      margin-bottom: 40px;
      opacity: 0;
      animation: fadeIn 1.4s ease-out 0.45s forwards;
    }
    #globe {
      width: 100%;
      height: 100%;
      cursor: grab;
    }
    #globe:active { cursor: grabbing; }
    .globe-wrap::before {
      content: "";
      position: absolute;
      inset: -6%;
      border: 1px dashed rgba(212, 175, 55, 0.22);
      border-radius: 50%;
      animation: spin-slow 90s linear infinite;
      pointer-events: none;
    }
    @keyframes spin-slow { to { transform: rotate(360deg); } }

    .tagline {
      font-family: var(--display);
      font-weight: 500;
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
      opacity: 0;
      animation: fadeUp 0.9s ease-out 0.6s forwards;
    }
    .tagline em {
      font-style: italic;
      color: var(--gold-bright);
    }
    .schedule {
      font-family: var(--display);
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0.28em;
      color: var(--white-dim);
      text-transform: uppercase;
      opacity: 0;
      animation: fadeUp 0.9s ease-out 0.7s forwards;
    }

    /* Single row directly under the wordmark — TBPN-style:
       "Find Boardroom Wire" label on the left, social icons + More Info on the right. */
    .find-row {
      width: 100%;
      max-width: 880px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
      margin-bottom: 64px;
      opacity: 0;
      animation: fadeUp 0.9s ease-out 0.3s forwards;
    }
    .find-row-right {
      display: flex;
      align-items: center;
      gap: 28px;
    }
    .find-us-label {
      font-family: var(--display);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.28em;
      color: var(--white-dim);
      text-transform: uppercase;
    }
    .socials {
      display: flex;
      gap: 22px;
      align-items: center;
    }
    .socials a {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      color: var(--white);
      transition: all 0.2s;
      text-decoration: none;
    }
    .socials a:hover {
      color: var(--gold-bright);
      transform: translateY(-2px);
    }
    .socials svg {
      width: 20px;
      height: 20px;
      fill: currentColor;
    }
    .more-info {
      display: inline-block;
      font-family: var(--display);
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 0.24em;
      color: var(--black);
      text-transform: uppercase;
      text-decoration: none;
      background: var(--gold-bright);
      border: none;
      padding: 18px 36px;
      transition: all 0.2s;
      white-space: nowrap;
      box-shadow: 0 4px 0 0 var(--gold);
    }
    .more-info:hover {
      background: var(--gold);
      box-shadow: 0 6px 0 0 #b8932e;
      transform: translateY(-2px);
    }
    .more-info:active {
      transform: translateY(2px);
      box-shadow: 0 2px 0 0 var(--gold);
    }

    /* ============ REEL (YouTube carousel) ============ */
    section.reel {
      border-top: 1px solid var(--line);
      padding: 64px 0 80px;
      position: relative;
      z-index: 5;
    }
    .reel-header {
      max-width: 1280px;
      margin: 0 auto 32px;
      padding: 0 48px;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
    }
    .reel-eyebrow {
      font-family: var(--display);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--gold-bright);
      margin-bottom: 8px;
    }
    .reel-title {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(28px, 3.5vw, 40px);
      letter-spacing: -0.02em;
      color: var(--white);
    }
    .reel-controls {
      display: flex;
      gap: 8px;
    }
    .reel-btn {
      width: 44px; height: 44px;
      border: 1px solid var(--line);
      background: transparent;
      color: var(--white);
      cursor: pointer;
      transition: all 0.18s;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .reel-btn:hover {
      border-color: var(--gold);
      color: var(--gold-bright);
    }
    .reel-btn svg { width: 18px; height: 18px; fill: currentColor; }

    .reel-track-wrap {
      position: relative;
      overflow: hidden;
    }
    .reel-track {
      display: flex;
      gap: 20px;
      padding: 0 48px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .reel-track::-webkit-scrollbar { display: none; }

    .reel-card {
      scroll-snap-align: start;
      flex: 0 0 calc((100% - 48px*2 - 20px*2) / 3);
      min-width: 280px;
      max-width: 480px;
      position: relative;
      display: block;
      text-decoration: none;
      color: var(--white);
      border: 1px solid var(--line);
      background: var(--black-soft);
      transition: border-color 0.2s, transform 0.25s;
    }
    .reel-card:hover {
      border-color: var(--gold);
      transform: translateY(-3px);
    }
    .reel-card .thumb {
      position: relative;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      background: var(--black-soft);
    }
    .reel-card .thumb img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s;
    }
    .reel-card:hover .thumb img { transform: scale(1.04); }
    .reel-card .thumb::after {
      content: "";
      position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 50%);
      pointer-events: none;
    }
    .reel-card .play {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.25s;
      pointer-events: none;
    }
    .reel-card:hover .play { opacity: 1; }
    .reel-card .play span {
      width: 64px; height: 64px;
      background: var(--gold-bright);
      color: var(--black);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .reel-card .play svg { width: 24px; height: 24px; margin-left: 4px; fill: currentColor; }
    .reel-card .meta {
      padding: 18px 20px 22px;
      position: relative;
    }
    .reel-card .meta h3 {
      font-family: var(--display);
      font-size: 16px;
      font-weight: 600;
      line-height: 1.35;
      color: var(--white);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .reel-card.placeholder .thumb {
      background: linear-gradient(135deg, #0a0a0a, #1a1a1a 50%, #0a0a0a);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .reel-card.placeholder .thumb::before {
      content: "";
      width: 56px; height: 56px;
      border: 1px solid var(--line);
      border-radius: 50%;
      background: rgba(212, 175, 55, 0.04);
    }

    /* Footer */
    footer.tail {
      border-top: 1px solid var(--line);
      padding: 28px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      font-family: var(--display);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--white-dim);
    }
    footer.tail a {
      color: inherit;
      text-decoration: none;
      transition: color 0.18s;
    }
    footer.tail a:hover { color: var(--gold-bright); }

    /* Animations */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* Responsive */
    @media (max-width: 720px) {
      .ticker { height: 46px; }
      .ticker-track { gap: 36px; padding-left: 20px; }
      .stat { font-size: 11px; letter-spacing: 0.12em; gap: 8px; }
      .stat .sep { margin-left: 36px; }
      .ticker-label { font-size: 11px; padding: 0 14px; gap: 8px; }
      .ticker-label .pulse { width: 8px; height: 8px; }
      main.hero { padding: 40px 24px 64px; }
      .wordmark { font-size: clamp(40px, 12vw, 64px); margin-bottom: 24px; }
      .find-row {
        flex-direction: column;
        gap: 20px;
        margin-bottom: 48px;
      }
      .find-row-right {
        flex-direction: column;
        gap: 18px;
      }
      .socials { gap: 20px; }
      .reel-header { padding: 0 24px; }
      .reel-track { padding: 0 24px; }
      footer.tail { padding: 20px 24px; flex-direction: column; align-items: flex-start; gap: 12px; }
    }
    @media (max-width: 520px) {
      .reel-card { flex-basis: 90%; min-width: 0; }
    }

    @media (prefers-reduced-motion: reduce) {
      /* Heavy motion (globe rotation, carousel autoplay, hero fades) respects
         the preference. The ticker keeps animating — it's a horizontal text
         crawl, not the kind of vestibular trigger this preference targets. */
      *, *::before, *::after {
        animation-duration: 0s !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0s !important;
      }
      .ticker-track {
        animation: ticker-scroll 28s linear infinite !important;
      }
      .reel-track { scroll-behavior: auto; }
    }
  </style>
</head>
<body>

  <!-- Live Wire ticker -->
  <div class="ticker">
    <div class="ticker-label">
      <span class="pulse"></span>
      <span>Live Wire</span>
    </div>
    <div class="ticker-stats" aria-label="Live channel statistics">
      <div class="ticker-track">
        <div class="stat">Videos <span class="v" data-stat="videos">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Subscribers <span class="v" data-stat="subs">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Total Views <span class="v" data-stat="views">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Top Episode <span class="v" data-stat="top">—</span><span class="sep" aria-hidden="true">·</span></div>
        <div class="stat">Newest <span class="v" data-stat="newest">—</span><span class="sep" aria-hidden="true">·</span></div>
        <!-- Duplicate set for seamless marquee loop -->
        <div class="stat" aria-hidden="true">Videos <span class="v" data-stat="videos">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Subscribers <span class="v" data-stat="subs">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Total Views <span class="v" data-stat="views">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Top Episode <span class="v" data-stat="top">—</span><span class="sep">·</span></div>
        <div class="stat" aria-hidden="true">Newest <span class="v" data-stat="newest">—</span><span class="sep">·</span></div>
      </div>
    </div>
  </div>

  <!-- Hero -->
  <main class="hero">
    <div class="wordmark" aria-label="Boardroom Wire">
      BOARDROOM<span class="wire">WIRE</span>
    </div>

    <div class="find-row">
      <div class="find-us-label">Find Boardroom Wire</div>
      <div class="find-row-right">
        <div class="socials">
          <a href="https://x.com/BoardroomWire" target="_blank" rel="noopener" title="X" aria-label="X">
            <svg viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.youtube.com/@BoardroomWire" target="_blank" rel="noopener" title="YouTube" aria-label="YouTube">
            <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
          <a href="https://substack.com/@boardroom1" target="_blank" rel="noopener" title="Substack" aria-label="Substack">
            <svg viewBox="0 0 24 24"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
          </a>
        </div>
        <a href="/about/" class="more-info">More Info</a>
      </div>
    </div>

    <div class="globe-wrap">
      <div id="globe"></div>
    </div>

    <h1 class="tagline">Infrastructure is <em>destiny.</em></h1>
    <p class="schedule">Weekly · Mondays · 9 AM ET</p>
  </main>

  <!-- Reel — YouTube thumbnail carousel -->
  <section class="reel" id="reel">
    <div class="reel-header">
      <div>
        <p class="reel-eyebrow">The Reel</p>
        <h2 class="reel-title">Latest from the channel</h2>
      </div>
      <div class="reel-controls">
        <button type="button" class="reel-btn" id="reel-prev" aria-label="Previous">
          <svg viewBox="0 0 24 24"><path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
        </button>
        <button type="button" class="reel-btn" id="reel-next" aria-label="Next">
          <svg viewBox="0 0 24 24"><path d="M10 6 8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
        </button>
      </div>
    </div>

    <div class="reel-track-wrap">
      <div class="reel-track" id="reel-track" role="list" aria-label="Latest videos">
        <!-- cards inserted by JS -->
      </div>
    </div>
  </section>

  <footer class="tail">
    <span>© 2026 Boardroom Wire</span>
    <a href="/about/">More Info</a>
  </footer>

  <!-- YouTube live data — both ticker and reel feed off one cached fetch -->
  <script>
    import { fetchChannelData, fmt, daysAgo } from '../lib/youtube';

    const setStat = (name: string, value: string) => {
      document.querySelectorAll(`[data-stat="${name}"]`).forEach((el) => {
        el.textContent = value;
      });
    };

    /* ============ Reel rendering ============ */
    const track = document.getElementById('reel-track')!;

    function renderReelPlaceholders(n = 6) {
      track.innerHTML = '';
      for (let i = 0; i < n; i++) {
        const card = document.createElement('div');
        card.className = 'reel-card placeholder';
        card.setAttribute('role', 'listitem');
        card.innerHTML = `<div class="thumb"></div><div class="meta"><h3>Episode ${i + 1}</h3></div>`;
        track.appendChild(card);
      }
    }

    function renderReelVideos(videos: Array<{ id: string; title: string; thumbnail: string }>) {
      track.innerHTML = '';
      for (const v of videos) {
        const a = document.createElement('a');
        a.className = 'reel-card';
        a.href = `https://www.youtube.com/watch?v=${v.id}`;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.setAttribute('role', 'listitem');
        a.setAttribute('aria-label', `Watch: ${v.title}`);
        a.innerHTML = `
          <div class="thumb">
            <img src="${v.thumbnail}" alt="" loading="lazy" />
            <div class="play"><span><svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></span></div>
          </div>
          <div class="meta"><h3>${v.title}</h3></div>
        `;
        track.appendChild(a);
      }
    }

    /* ============ Single fetch feeds both ============ */
    async function hydrate() {
      const data = await fetchChannelData();
      if (!data) {
        // No key or fetch failed — placeholders for the reel; ticker keeps em-dashes
        renderReelPlaceholders();
        return;
      }

      // Ticker
      setStat('videos', fmt(data.videos));
      setStat('subs',   fmt(data.subs));
      setStat('views',  fmt(data.views));
      setStat('top',    data.topVideo ? `${fmt(data.topVideo.views)} views` : '—');
      setStat('newest', data.newest ? daysAgo(data.newest.publishedAt) : '—');

      // Reel
      if (data.reel.length > 0) {
        renderReelVideos(data.reel);
      } else {
        renderReelPlaceholders();
      }
    }

    /* ============ Reel auto-advance + prev/next ============ */
    function setupReelControls() {
      const cardWidth = () => {
        const card = track.querySelector('.reel-card');
        if (!card) return 0;
        const styles = getComputedStyle(track);
        const gap = parseFloat(styles.gap) || 0;
        return card.getBoundingClientRect().width + gap;
      };

      document.getElementById('reel-prev')!.addEventListener('click', () => {
        track.scrollBy({ left: -cardWidth(), behavior: 'smooth' });
      });
      document.getElementById('reel-next')!.addEventListener('click', () => {
        track.scrollBy({ left: cardWidth(), behavior: 'smooth' });
      });

      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduced) return;

      let paused = false;
      const reelSection = document.getElementById('reel')!;
      reelSection.addEventListener('mouseenter', () => { paused = true; });
      reelSection.addEventListener('mouseleave', () => { paused = false; });
      reelSection.addEventListener('focusin',  () => { paused = true; });
      reelSection.addEventListener('focusout', () => { paused = false; });

      setInterval(() => {
        if (paused) return;
        const w = cardWidth();
        if (!w) return;
        const max = track.scrollWidth - track.clientWidth - 4;
        if (track.scrollLeft >= max) {
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: w, behavior: 'smooth' });
        }
      }, 5000);
    }

    hydrate().then(setupReelControls);
    // Refresh every 5 minutes — picks up cached or fresh data automatically
    setInterval(hydrate, 5 * 60_000);
  </script>

  <!-- globe.gl hero globe — capital-markets cities + arcs + rings + click-to-emit -->
  <script>
    import Globe from 'globe.gl';

    const GOLD = '#D4AF37';
    const GOLD_BRIGHT = '#F2CB52';
    const FLIGHT_TIME = 1000;
    const RINGS_MAX_R = 5;
    const RING_PROPAGATION_SPEED = 5;
    const AMBIENT_INTERVAL = 2500;
    const MAX_AMBIENT_ARCS = 6;

    // Strategic global capital-markets / tech-infrastructure centers.
    const cities = [
      { name: 'New York',      lat:  40.7128, lng:  -74.0060 },
      { name: 'San Francisco', lat:  37.7749, lng: -122.4194 },
      { name: 'Toronto',       lat:  43.6532, lng:  -79.3832 },
      { name: 'São Paulo',     lat: -23.5505, lng:  -46.6333 },
      { name: 'London',        lat:  51.5074, lng:   -0.1278 },
      { name: 'Frankfurt',     lat:  50.1109, lng:    8.6821 },
      { name: 'Zurich',        lat:  47.3769, lng:    8.5417 },
      { name: 'Dubai',         lat:  25.2048, lng:   55.2708 },
      { name: 'Mumbai',        lat:  19.0760, lng:   72.8777 },
      { name: 'Singapore',     lat:   1.3521, lng:  103.8198 },
      { name: 'Hong Kong',     lat:  22.3193, lng:  114.1694 },
      { name: 'Shanghai',      lat:  31.2304, lng:  121.4737 },
      { name: 'Seoul',         lat:  37.5665, lng:  126.9780 },
      { name: 'Tokyo',         lat:  35.6762, lng:  139.6503 },
    ];

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const useHex = new URLSearchParams(window.location.search).get('hex') === '1';

    const arcs: Array<{ startLat: number; startLng: number; endLat: number; endLng: number }> = [];
    const rings: Array<{ lat: number; lng: number }> = [];

    const el = document.getElementById('globe')!;
    const size = el.clientWidth;

    const globe = new (Globe as any)(el)
      .width(size)
      .height(size)
      .backgroundColor('rgba(0,0,0,0)')
      .showAtmosphere(false)
      .globeImageUrl(null as any)
      .pointsData(cities)
      .pointLat('lat')
      .pointLng('lng')
      .pointColor(() => GOLD_BRIGHT)
      .pointAltitude(0.01)
      .pointRadius(0.4)
      .pointResolution(12)
      .arcsData(arcs)
      .arcColor(() => GOLD)
      .arcDashLength(0.4)
      .arcDashGap(2)
      .arcDashAnimateTime(2000)
      .arcStroke(0.4)
      .arcsTransitionDuration(0)
      .ringsData(rings)
      .ringColor(() => (t: number) => `rgba(212, 175, 55, ${1 - t})`)
      .ringMaxRadius(RINGS_MAX_R)
      .ringPropagationSpeed(RING_PROPAGATION_SPEED)
      .ringRepeatPeriod((FLIGHT_TIME * RINGS_MAX_R) / RING_PROPAGATION_SPEED / 3);

    // Pure black sphere so the back of the globe doesn't show points/arcs through.
    const mat = globe.globeMaterial() as any;
    if (mat && mat.color && typeof mat.color.set === 'function') {
      mat.color.set('#000000');
    }

    // Auto-rotate (unless user prefers reduced motion)
    const controls = (globe.controls() as any);
    if (controls) {
      controls.autoRotate = !reduced;
      controls.autoRotateSpeed = 0.4;
      controls.enableZoom = false; // don't let scroll-zoom hijack page scroll
    }

    // Hex polygons — only when ?hex=1
    if (useHex) {
      fetch('https://unpkg.com/globe.gl/example/datasets/ne_110m_admin_0_countries.geojson')
        .then((r) => r.json())
        .then((geo) => {
          globe
            .hexPolygonsData(geo.features)
            .hexPolygonResolution(3)
            .hexPolygonMargin(0.3)
            .hexPolygonAltitude(0.005)
            .hexPolygonColor(() => 'rgba(212, 175, 55, 0.6)');
        })
        .catch((err) => console.warn('[globe] hex polygons fetch failed:', err));
    }

    // Resize handling — keep canvas square to wrapper
    const onResize = () => {
      const s = el.clientWidth;
      globe.width(s).height(s);
    };
    window.addEventListener('resize', onResize);

    // ====== Click-to-emit: clicked city → arc to random other city → ring at destination ======
    const fireArc = (start: typeof cities[number], end: typeof cities[number]) => {
      const arc = {
        startLat: start.lat,
        startLng: start.lng,
        endLat: end.lat,
        endLng: end.lng,
      };
      arcs.push(arc);
      globe.arcsData([...arcs]);
      // Remove arc after full flight + dash trail clears
      setTimeout(() => {
        const i = arcs.indexOf(arc);
        if (i >= 0) arcs.splice(i, 1);
        globe.arcsData([...arcs]);
      }, FLIGHT_TIME * 2);

      // Emit ring at destination when arc lands
      setTimeout(() => {
        const ring = { lat: end.lat, lng: end.lng };
        rings.push(ring);
        globe.ringsData([...rings]);
        setTimeout(() => {
          const j = rings.indexOf(ring);
          if (j >= 0) rings.splice(j, 1);
          globe.ringsData([...rings]);
        }, (FLIGHT_TIME * RINGS_MAX_R) / RING_PROPAGATION_SPEED);
      }, FLIGHT_TIME);
    };

    globe.onPointClick((point: any) => {
      let target = cities[Math.floor(Math.random() * cities.length)];
      // pick again if we landed on the source
      while (target === point && cities.length > 1) {
        target = cities[Math.floor(Math.random() * cities.length)];
      }
      fireArc(point as typeof cities[number], target);
    });

    // ====== Ambient activity — random arc every 2.5s, capped at 6 ======
    if (!reduced) {
      setInterval(() => {
        if (arcs.length >= MAX_AMBIENT_ARCS) return;
        const a = cities[Math.floor(Math.random() * cities.length)];
        let b = cities[Math.floor(Math.random() * cities.length)];
        while (b === a) b = cities[Math.floor(Math.random() * cities.length)];
        fireArc(a, b);
      }, AMBIENT_INTERVAL);
    }
  </script>

