---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import VideoCard from '../../components/VideoCard.astro';
import ResearchCard from '../../components/ResearchCard.astro';

export async function getStaticPaths() {
  const [articles, videos, research] = await Promise.all([
    getCollection('articles', ({ data }) => !data.draft),
    getCollection('videos', ({ data }) => !data.draft),
    getCollection('research', ({ data }) => !data.draft),
  ]);

  const tags = new Set<string>();
  for (const entry of [...articles, ...videos, ...research]) {
    for (const tag of entry.data.tags) tags.add(tag);
  }

  return [...tags].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const sortByDateDesc = (
  a: { data: { publishDate: Date } },
  b: { data: { publishDate: Date } },
) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf();

const filterByTag = ({ data }: { data: { tags: string[]; draft: boolean } }) =>
  !data.draft && data.tags.includes(tag!);

const articles = (await getCollection('articles', filterByTag)).sort(
  sortByDateDesc,
) as CollectionEntry<'articles'>[];
const videos = (await getCollection('videos', filterByTag)).sort(
  sortByDateDesc,
) as CollectionEntry<'videos'>[];
const research = (await getCollection('research', filterByTag)).sort(
  sortByDateDesc,
) as CollectionEntry<'research'>[];
---

<BaseLayout
  title={`#${tag}`}
  description={`Boardroom Wire coverage tagged "${tag}".`}
>
  <main class="mx-auto max-w-screen-2xl px-6 py-16 md:py-24">
    <header class="mb-12 max-w-3xl">
      <p class="text-xs uppercase tracking-wider text-gold">Tag</p>
      <h1 class="mt-4 font-serif text-4xl text-cream md:text-6xl">#{tag}</h1>
    </header>

    <div class="space-y-16">
      {
        articles.length > 0 && (
          <section>
            <h2 class="mb-8 font-serif text-3xl text-cream md:text-4xl">
              Articles
            </h2>
            <div class="grid gap-8 md:grid-cols-3">
              {articles.map((entry) => (
                <ArticleCard entry={entry} />
              ))}
            </div>
          </section>
        )
      }

      {
        videos.length > 0 && (
          <section>
            <h2 class="mb-8 font-serif text-3xl text-cream md:text-4xl">
              Videos
            </h2>
            <div class="grid gap-8 md:grid-cols-3">
              {videos.map((entry) => (
                <VideoCard entry={entry} />
              ))}
            </div>
          </section>
        )
      }

      {
        research.length > 0 && (
          <section>
            <h2 class="mb-8 font-serif text-3xl text-cream md:text-4xl">
              Research
            </h2>
            <div class="grid gap-8 md:grid-cols-2">
              {research.map((entry) => (
                <ResearchCard entry={entry} />
              ))}
            </div>
          </section>
        )
      }
    </div>
  </main>
</BaseLayout>
