---
import ModernLayout from '../layouts/ModernLayout.astro';

const previewArticles = [
  {
    category: 'Business of AI',
    title: 'OpenAI is structurally cooked. The numbers, finally.',
    dek: 'A clean read of the latest revenue disclosures alongside compute spend. The trajectory does not survive contact with public-market scrutiny.',
    date: 'APR 22, 2026',
    readTime: '7 MIN',
  },
  {
    category: 'Private Markets',
    title: 'Anthropic’s last private round, decoded.',
    dek: 'What the term sheet actually says about preference stack, secondary blocks, and the IPO timeline that nobody in the deck wanted to commit to in writing.',
    date: 'APR 18, 2026',
    readTime: '11 MIN',
  },
  {
    category: 'Titan Strategy',
    title: 'Microsoft’s 49% claim on OpenAI economics: the playbook in plain sight.',
    dek: 'Eight years selling into hyperscaler procurement teaches you what “strategic partnership” actually means on a balance sheet.',
    date: 'APR 14, 2026',
    readTime: '9 MIN',
  },
];

const previewResearch = [
  {
    title: 'AI Capex Tracker — Q1 2026',
    dek: 'Quarterly compute capital expenditure across the seven hyperscalers, normalized for accounting treatment.',
    date: 'APR 10, 2026',
  },
  {
    title: 'Frontier Lab Valuation Map',
    dek: 'Implied per-share value across primary, tender, and secondary markets for the eight major frontier labs.',
    date: 'APR 02, 2026',
  },
];

const pillars = [
  { slug: 'business-of-ai', label: 'Business of AI', desc: 'Revenue, unit economics, market structure.' },
  { slug: 'private-markets', label: 'Private Markets', desc: 'Term sheets, preference stacks, secondaries.' },
  { slug: 'titan-strategy', label: 'Titan Strategy', desc: 'How the hyperscalers actually play this.' },
  { slug: 'market-dynamics', label: 'Market Dynamics', desc: 'Compute, talent, supply chain, capital.' },
];

// Ticker phrases — brand voice from the spec, no fake numbers.
const tickerPhrases = [
  'Forensic depth, not hot takes',
  'The numbers tell the story',
  'Strategic breakdowns',
  'PE/banker lens on AI',
  'Read the boardroom',
  'No LinkedIn cadence',
];
---

<ModernLayout
  title="Heavy preview"
  description="Boardroom Wire — forensic analysis of the companies shaping the future."
  variant="heavy"
>
  {/* Custom cursor (hidden on touch / keyboard-only) */}
  <div id="cursor-dot" class="cursor-dot" aria-hidden="true"></div>
  <div id="cursor-ring" class="cursor-ring" aria-hidden="true"></div>

  {/* Modern nav */}
  <header class="fixed top-9 inset-x-0 z-50 border-b border-ink-border/60 bg-ink/70 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/v2-heavy/" class="font-modern font-bold text-lg tracking-tight" data-cursor="link">
        Boardroom<span class="text-electric">Wire</span>
      </a>
      <nav class="hidden md:flex items-center gap-8">
        <a href="/articles/" class="text-sm text-paper-dim hover:text-paper transition-colors" data-cursor="link">Articles</a>
        <a href="/videos/" class="text-sm text-paper-dim hover:text-paper transition-colors" data-cursor="link">Videos</a>
        <a href="/research/" class="text-sm text-paper-dim hover:text-paper transition-colors" data-cursor="link">Research</a>
        <a href="/about/" class="text-sm text-paper-dim hover:text-paper transition-colors" data-cursor="link">About</a>
        <a
          href="/newsletter/"
          class="magnetic text-sm bg-electric hover:bg-electric-bright text-ink px-4 py-2 rounded-md font-semibold transition-colors"
          data-cursor="link"
        >
          Subscribe
        </a>
      </nav>
    </div>
  </header>

  {/* Hero */}
  <section class="relative pt-44 pb-20 overflow-hidden">
    <div class="absolute inset-0 -z-10" aria-hidden="true">
      <div class="absolute top-0 left-1/4 w-[700px] h-[700px] rounded-full bg-electric/25 blur-3xl animate-mesh-drift"></div>
      <div
        class="absolute top-1/3 right-1/5 w-[500px] h-[500px] rounded-full bg-electric/15 blur-3xl animate-mesh-drift"
        style="animation-delay: -8s"
      ></div>
      <div
        class="absolute bottom-0 left-1/2 w-[400px] h-[400px] rounded-full bg-electric/10 blur-3xl animate-mesh-drift"
        style="animation-delay: -16s"
      ></div>
    </div>

    <div class="max-w-7xl mx-auto px-6">
      <p class="text-sm font-medium text-electric mb-6 reveal">
        Forensic AI analysis · Volume I
      </p>
      <h1 class="font-modern text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[0.95] reveal" style="transition-delay: 100ms">
        The business of AI,<br />
        <span class="bg-gradient-to-r from-electric via-electric-bright to-paper bg-clip-text text-transparent">decoded.</span>
      </h1>
      <p class="mt-10 max-w-2xl text-lg md:text-xl text-paper-dim leading-relaxed reveal" style="transition-delay: 200ms">
        Bloomberg-style depth on AI and the tech industry. Strategic breakdowns, not product reviews. Eight years in private-equity tech sales applied to the companies shaping the next decade.
      </p>
      <div class="mt-12 flex flex-wrap gap-4 reveal" style="transition-delay: 300ms">
        <a
          href="/articles/"
          class="magnetic px-6 py-3 rounded-md bg-electric hover:bg-electric-bright text-ink font-semibold transition-colors"
          data-cursor="link"
        >
          Read the analysis
        </a>
        <a
          href="/newsletter/"
          class="magnetic px-6 py-3 rounded-md border border-ink-border hover:border-electric/50 text-paper transition-colors"
          data-cursor="link"
        >
          Get the newsletter
        </a>
      </div>
    </div>
  </section>

  {/* Live ticker */}
  <section class="border-y border-ink-border bg-ink-elevated/50 overflow-hidden" aria-label="Tagline ticker">
    <div class="flex animate-ticker whitespace-nowrap py-4">
      {[...Array(2)].flatMap((_, dup) =>
        tickerPhrases.map((phrase, i) => (
          <span class="inline-flex items-center" data-key={`${dup}-${i}`}>
            <span class="px-8 text-sm font-mono text-paper-dim">{phrase}</span>
            <span class="text-electric" aria-hidden="true">●</span>
          </span>
        ))
      )}
    </div>
  </section>

  {/* Pillars strip */}
  <section class="bg-ink-elevated/20">
    <div class="max-w-7xl mx-auto px-6 py-20">
      <p class="text-xs uppercase tracking-[0.2em] text-paper-dim mb-8 reveal">Coverage pillars</p>
      <div class="grid md:grid-cols-4 gap-6">
        {pillars.map((p, i) => (
          <a
            href={`/categories/${p.slug}/`}
            class="modern-card block p-6 rounded-lg border border-ink-border hover:border-electric/40 transition-all reveal"
            style={`transition-delay: ${i * 80}ms`}
            data-cursor="link"
          >
            <div class="text-electric font-mono text-xs mb-3">0{i + 1}</div>
            <h3 class="font-modern text-lg font-semibold text-paper mb-2">{p.label}</h3>
            <p class="text-sm text-paper-dim leading-relaxed">{p.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Stats counter */}
  <section class="border-y border-ink-border">
    <div class="max-w-7xl mx-auto px-6 py-20 grid grid-cols-2 md:grid-cols-4 gap-8">
      {[
        { stat: '8+', label: 'Years in PE tech sales' },
        { stat: '24', label: 'Companies tracked' },
        { stat: '4T', label: 'Combined market cap covered' },
        { stat: '52', label: 'Forensic dispatches a year' },
      ].map((s, i) => (
        <div class="reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="font-modern text-5xl md:text-6xl font-bold text-paper counter" data-target={s.stat}>{s.stat}</div>
          <div class="mt-2 text-sm text-paper-dim">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  {/* Latest analysis */}
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="flex items-end justify-between mb-12 reveal">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-electric mb-3">Latest</p>
        <h2 class="font-modern text-3xl md:text-5xl font-bold tracking-tight">Recent analysis</h2>
      </div>
      <a href="/articles/" class="hidden md:inline-flex items-center gap-2 text-sm text-electric hover:text-electric-bright" data-cursor="link">
        View all
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {previewArticles.map((a, i) => (
        <a
          href="/articles/"
          class="modern-card block p-6 rounded-lg border border-ink-border bg-ink-elevated/40 hover:border-electric/40 hover:-translate-y-0.5 transition-all duration-300 reveal"
          style={`transition-delay: ${i * 100}ms`}
          data-cursor="link"
        >
          <div class="flex items-center gap-3 text-xs">
            <span class="text-electric font-medium uppercase tracking-wider">{a.category}</span>
            <span class="text-paper-dim/60">·</span>
            <span class="text-paper-dim font-mono">{a.readTime}</span>
          </div>
          <h3 class="mt-5 font-modern text-xl font-semibold leading-snug text-paper">
            {a.title}
          </h3>
          <p class="mt-3 text-sm text-paper-dim leading-relaxed line-clamp-3">{a.dek}</p>
          <div class="mt-8 pt-5 border-t border-ink-border flex items-center justify-between">
            <span class="text-xs font-mono text-paper-dim">{a.date}</span>
            <span class="text-electric" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {/* Research */}
  <section class="border-t border-ink-border bg-ink-elevated/30">
    <div class="max-w-7xl mx-auto px-6 py-24">
      <div class="mb-12 reveal">
        <p class="text-xs uppercase tracking-[0.2em] text-electric mb-3">Research</p>
        <h2 class="font-modern text-3xl md:text-5xl font-bold tracking-tight">Primary-source dashboards</h2>
        <p class="mt-4 max-w-2xl text-paper-dim">Quarterly trackers and valuation maps, refreshed as new filings drop.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {previewResearch.map((r, i) => (
          <a
            href="/research/"
            class="modern-card block rounded-lg border border-ink-border bg-ink overflow-hidden hover:border-electric/40 transition-all reveal"
            style={`transition-delay: ${i * 120}ms`}
            data-cursor="link"
          >
            <div class="aspect-[16/9] bg-gradient-to-br from-electric/10 via-ink-elevated to-ink relative">
              <svg class="absolute inset-0 w-full h-full" viewBox="0 0 400 225" preserveAspectRatio="none" aria-hidden="true">
                <polyline points="0,180 50,160 100,165 150,120 200,140 250,90 300,100 350,60 400,70" fill="none" stroke="#3b82f6" stroke-width="1.5" opacity="0.6"/>
                <polyline points="0,200 50,190 100,180 150,170 200,150 250,135 300,115 350,95 400,80" fill="none" stroke="#60a5fa" stroke-width="1.5" opacity="0.4"/>
              </svg>
            </div>
            <div class="p-6">
              <h3 class="font-modern text-xl font-semibold text-paper">{r.title}</h3>
              <p class="mt-2 text-sm text-paper-dim line-clamp-2">{r.dek}</p>
              <p class="mt-4 text-xs font-mono text-paper-dim/70">{r.date}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Newsletter */}
  <section class="max-w-3xl mx-auto px-6 py-24 text-center">
    <h2 class="font-modern text-3xl md:text-5xl font-bold tracking-tight reveal">
      One forensic dispatch a week.
    </h2>
    <p class="mt-6 text-paper-dim text-lg reveal" style="transition-delay: 100ms">
      Strategic depth, no hype. Cancel anytime.
    </p>
    <form class="mt-10 flex flex-col sm:flex-row gap-3 max-w-lg mx-auto reveal" style="transition-delay: 200ms" action="#" method="post">
      <input
        type="email"
        placeholder="you@company.com"
        class="flex-1 px-4 py-3 rounded-md bg-ink-elevated border border-ink-border text-paper placeholder:text-paper-dim/60 focus:border-electric focus:outline-none transition-colors"
        data-cursor="text"
      />
      <button class="magnetic px-6 py-3 rounded-md bg-electric hover:bg-electric-bright text-ink font-semibold transition-colors" data-cursor="link">
        Subscribe
      </button>
    </form>
  </section>

  {/* Footer */}
  <footer class="border-t border-ink-border">
    <div class="max-w-7xl mx-auto px-6 py-12 flex flex-col md:flex-row md:items-center md:justify-between gap-6 text-sm text-paper-dim">
      <div>© 2026 Boardroom Wire</div>
      <div class="flex gap-6">
        <a href="/about/" class="hover:text-paper" data-cursor="link">About</a>
        <a href="#" class="hover:text-paper" data-cursor="link">YouTube</a>
        <a href="#" class="hover:text-paper" data-cursor="link">X</a>
        <a href="/rss.xml" class="hover:text-paper" data-cursor="link">RSS</a>
      </div>
    </div>
  </footer>

  <style>
    /* Custom cursor — only on devices with hover + fine pointer */
    .cursor-dot,
    .cursor-ring {
      pointer-events: none;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 100;
      border-radius: 9999px;
      transform: translate(-50%, -50%);
      opacity: 0;
      transition: opacity 0.3s, width 0.25s, height 0.25s, background-color 0.25s, border-color 0.25s;
    }
    .cursor-dot {
      width: 6px;
      height: 6px;
      background: #f5f5f0;
    }
    .cursor-ring {
      width: 36px;
      height: 36px;
      border: 1.5px solid rgb(245 245 240 / 0.4);
      transition:
        transform 0.18s ease-out,
        opacity 0.3s,
        width 0.25s,
        height 0.25s,
        border-color 0.25s,
        background-color 0.25s;
    }
    .cursor-ring.is-link {
      width: 56px;
      height: 56px;
      background: rgb(59 130 246 / 0.15);
      border-color: #3b82f6;
    }
    .cursor-ring.is-text {
      width: 4px;
      height: 28px;
      border-radius: 2px;
      background: #3b82f6;
      border-color: transparent;
    }

    @media (hover: hover) and (pointer: fine) {
      .modern-root,
      .modern-root * {
        cursor: none !important;
      }
      .cursor-dot,
      .cursor-ring {
        opacity: 1;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .cursor-dot,
      .cursor-ring {
        display: none;
      }
    }
  </style>

  <script>
    (() => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const fine = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

      // ---- Custom cursor ----
      if (fine && !reduced) {
        const dot = document.getElementById('cursor-dot');
        const ring = document.getElementById('cursor-ring');
        if (dot && ring) {
          let dx = 0, dy = 0, rx = 0, ry = 0;
          window.addEventListener('mousemove', (e) => {
            dx = e.clientX;
            dy = e.clientY;
            dot.style.transform = `translate(${dx}px, ${dy}px) translate(-50%, -50%)`;
          });
          // Ring eases toward dot for a soft trail
          const tick = () => {
            rx += (dx - rx) * 0.18;
            ry += (dy - ry) * 0.18;
            ring.style.transform = `translate(${rx}px, ${ry}px) translate(-50%, -50%)`;
            requestAnimationFrame(tick);
          };
          tick();

          // Cursor variants on interactive elements
          document.querySelectorAll('[data-cursor]').forEach((el) => {
            const variant = el.getAttribute('data-cursor');
            el.addEventListener('mouseenter', () => {
              ring.classList.remove('is-link', 'is-text');
              if (variant === 'link') ring.classList.add('is-link');
              if (variant === 'text') ring.classList.add('is-text');
            });
            el.addEventListener('mouseleave', () => {
              ring.classList.remove('is-link', 'is-text');
            });
          });
        }
      }

      // ---- Magnetic buttons ----
      if (fine && !reduced) {
        document.querySelectorAll<HTMLElement>('.magnetic').forEach((el) => {
          el.addEventListener('mousemove', (e) => {
            const rect = el.getBoundingClientRect();
            const cx = rect.left + rect.width / 2;
            const cy = rect.top + rect.height / 2;
            const dx = (e.clientX - cx) * 0.18;
            const dy = (e.clientY - cy) * 0.18;
            el.style.transform = `translate(${dx}px, ${dy}px)`;
          });
          el.addEventListener('mouseleave', () => {
            el.style.transform = '';
          });
        });
      }

      // ---- Counter rollup ----
      if (!reduced) {
        const counters = document.querySelectorAll<HTMLElement>('.counter');
        const rollupObs = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (!e.isIntersecting) continue;
              const el = e.target as HTMLElement;
              const target = el.dataset.target ?? '';
              const match = target.match(/^(\d+(?:\.\d+)?)(.*)$/);
              if (!match) continue;
              const num = parseFloat(match[1]);
              const suffix = match[2];
              const dur = 1200;
              const start = performance.now();
              const step = (now: number) => {
                const t = Math.min((now - start) / dur, 1);
                const eased = 1 - Math.pow(1 - t, 3);
                const v = num * eased;
                el.textContent = (Number.isInteger(num) ? Math.round(v).toString() : v.toFixed(1)) + suffix;
                if (t < 1) requestAnimationFrame(step);
                else el.textContent = target;
              };
              requestAnimationFrame(step);
              rollupObs.unobserve(el);
            }
          },
          { threshold: 0.5 },
        );
        counters.forEach((c) => rollupObs.observe(c));
      }
    })();
  </script>
</ModernLayout>
