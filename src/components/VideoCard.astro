---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'videos'>;
}

const { entry } = Astro.props;
const { title, dek, runtime, youtubeId } = entry.data;
const thumbnail = `https://i.ytimg.com/vi/${youtubeId}/maxresdefault.jpg`;
---

<a
  href={`/videos/${entry.id}/`}
  class="group block border border-gray-line transition-colors hover:bg-navy-soft"
>
  <div class="relative aspect-video overflow-hidden bg-navy-soft">
    <img
      src={thumbnail}
      alt=""
      loading="lazy"
      class="h-full w-full object-cover"
    />
    <span
      class="absolute bottom-3 left-3 bg-navy/90 px-2 py-1 text-xs uppercase tracking-wider text-cream-muted"
    >
      {runtime}
    </span>
  </div>
  <div class="p-6">
    <p class="text-xs uppercase tracking-wider text-gold">Watch</p>
    <h3
      class="mt-4 line-clamp-2 font-serif text-2xl text-cream transition-colors group-hover:text-gold"
    >
      {title}
    </h3>
    <p class="mt-3 line-clamp-3 text-sm text-cream-muted">{dek}</p>
  </div>
</a>
