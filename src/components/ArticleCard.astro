---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/format-date';

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props;
const { title, dek, category, publishDate, readTime } = entry.data;
const categoryLabel = category.replace(/-/g, ' ');
---

<a
  href={`/articles/${entry.id}/`}
  class="group block border border-gray-line p-6 transition-colors hover:bg-navy-soft"
>
  <p class="text-xs uppercase tracking-wider text-gold">
    {categoryLabel}{readTime && ` · ${readTime} MIN`}
  </p>
  <h3 class="mt-4 line-clamp-2 font-serif text-2xl text-cream transition-colors group-hover:text-gold">
    {title}
  </h3>
  <p class="mt-3 line-clamp-3 text-sm text-cream-muted">
    {dek}
  </p>
  <p class="mt-6 text-xs uppercase tracking-wider text-cream-muted">
    {formatDate(publishDate)} <span class="text-gold">→</span>
  </p>
</a>
