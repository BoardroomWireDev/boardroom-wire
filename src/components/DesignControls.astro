---
// Floating compare panel for the /v2-minimal preview.
// Toggles data-wordmark and data-backdrop on document.documentElement,
// which CSS uses to switch which wordmark and which backdrop is visible.
// Persists choices to localStorage so the about page renders the same combo.

const wordmarks = [
  { key: '1', label: 'BoardroomWire' },
  { key: '2', label: 'BOARDROOM WIRE' },
  { key: '3', label: 'BOARDROOMWIRE' },
];
const backdrops = [
  { key: 'mesh', label: 'Mesh' },
  { key: 'grid', label: 'Grid' },
  { key: 'noise', label: 'Noise' },
  { key: 'layered', label: 'Layered' },
];
---

<aside
  id="design-controls"
  class="fixed bottom-6 right-6 z-[55] hidden max-w-xs flex-col gap-3 rounded-lg border border-ink-border bg-ink-elevated/95 p-4 backdrop-blur-md md:flex"
  aria-label="Design comparison controls"
>
  <div class="flex items-center justify-between gap-4">
    <p class="text-[10px] font-mono uppercase tracking-[0.2em] text-paper-dim">Compare</p>
    <button
      id="design-controls-toggle"
      type="button"
      class="text-paper-dim hover:text-paper"
      aria-label="Hide compare panel"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" class="h-4 w-4" aria-hidden="true">
        <path d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div>
    <p class="mb-2 text-[10px] font-mono uppercase tracking-[0.15em] text-paper-dim/70">Wordmark</p>
    <div class="flex flex-col gap-1.5" role="radiogroup" aria-label="Wordmark variant">
      {
        wordmarks.map((w) => (
          <button
            type="button"
            class="design-control-btn rounded-md border border-ink-border bg-ink/40 px-3 py-2 text-left text-xs text-paper-dim transition-colors hover:border-electric/40 hover:text-paper data-[active=true]:border-electric data-[active=true]:bg-electric data-[active=true]:text-ink data-[active=true]:font-semibold"
            data-target="wordmark"
            data-key={w.key}
            role="radio"
          >
            {w.label}
          </button>
        ))
      }
    </div>
  </div>

  <div>
    <p class="mb-2 text-[10px] font-mono uppercase tracking-[0.15em] text-paper-dim/70">Backdrop</p>
    <div class="grid grid-cols-2 gap-1.5" role="radiogroup" aria-label="Backdrop variant">
      {
        backdrops.map((b) => (
          <button
            type="button"
            class="design-control-btn rounded-md border border-ink-border bg-ink/40 px-3 py-2 text-xs text-paper-dim transition-colors hover:border-electric/40 hover:text-paper data-[active=true]:border-electric data-[active=true]:bg-electric data-[active=true]:text-ink data-[active=true]:font-semibold"
            data-target="backdrop"
            data-key={b.key}
            role="radio"
          >
            {b.label}
          </button>
        ))
      }
    </div>
  </div>
</aside>

<button
  id="design-controls-show"
  type="button"
  class="fixed bottom-6 right-6 z-[55] hidden h-12 w-12 items-center justify-center rounded-full border border-ink-border bg-ink-elevated/95 text-paper-dim backdrop-blur-md transition-colors hover:border-electric/60 hover:text-electric"
  aria-label="Show compare panel"
  hidden
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" class="h-5 w-5" aria-hidden="true">
    <path d="M3 6h18M3 12h18M3 18h18"></path>
  </svg>
</button>

<script>
  const STORAGE = {
    wordmark: 'bw-preview-wordmark',
    backdrop: 'bw-preview-backdrop',
    panel: 'bw-preview-panel',
  };
  const DEFAULTS = { wordmark: '1', backdrop: 'mesh' };

  const root = document.documentElement;
  const panel = document.getElementById('design-controls');
  const showBtn = document.getElementById('design-controls-show');
  const toggleBtn = document.getElementById('design-controls-toggle');

  // Apply saved or default selections.
  const apply = (target: 'wordmark' | 'backdrop', key: string) => {
    root.dataset[target] = key;
    localStorage.setItem(STORAGE[target], key);
    document.querySelectorAll<HTMLElement>(`[data-target="${target}"]`).forEach((b) => {
      b.dataset.active = b.dataset.key === key ? 'true' : 'false';
    });
  };

  apply('wordmark', localStorage.getItem(STORAGE.wordmark) ?? DEFAULTS.wordmark);
  apply('backdrop', localStorage.getItem(STORAGE.backdrop) ?? DEFAULTS.backdrop);

  document.querySelectorAll<HTMLElement>('.design-control-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target as 'wordmark' | 'backdrop' | undefined;
      const key = btn.dataset.key;
      if (target && key) apply(target, key);
    });
  });

  // Panel show/hide (some users want to focus on the page itself).
  const setPanel = (open: boolean) => {
    panel?.classList.toggle('hidden', !open);
    panel?.classList.toggle('flex', open);
    showBtn?.toggleAttribute('hidden', open);
    showBtn?.classList.toggle('flex', !open);
    showBtn?.classList.toggle('hidden', open);
    localStorage.setItem(STORAGE.panel, open ? 'open' : 'closed');
  };
  setPanel(localStorage.getItem(STORAGE.panel) !== 'closed');
  toggleBtn?.addEventListener('click', () => setPanel(false));
  showBtn?.addEventListener('click', () => setPanel(true));
</script>
