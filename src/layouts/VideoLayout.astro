---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import { formatDate } from '../utils/format-date';

interface Props {
  entry: CollectionEntry<'videos'>;
}

const { entry } = Astro.props;
const { title, dek, category, publishDate, youtubeId, runtime, keyTakeaways } =
  entry.data;
const categoryLabel = category.replace(/-/g, ' ');

// runtime is validated as mm:ss (or hh:mm) by the schema; convert to ISO 8601
// duration for the VideoObject JSON-LD.
function runtimeToIso(rt: string): string {
  const parts = rt.split(':').map(Number);
  if (parts.length === 2) {
    const [m, s] = parts;
    return `PT${m}M${s}S`;
  }
  if (parts.length === 3) {
    const [h, m, s] = parts;
    return `PT${h}H${m}M${s}S`;
  }
  return 'PT0S';
}

const videoJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: title,
  description: dek,
  uploadDate: publishDate.toISOString(),
  thumbnailUrl: `https://i.ytimg.com/vi/${youtubeId}/maxresdefault.jpg`,
  embedUrl: `https://www.youtube-nocookie.com/embed/${youtubeId}`,
  duration: runtimeToIso(runtime),
};
---

<BaseLayout title={title} description={dek} ogType="video.other">
  <Fragment slot="head">
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(videoJsonLd)}
    />
  </Fragment>

  <article>
    <header class="mx-auto max-w-3xl px-6 pt-16 md:pt-24">
      <p class="text-xs uppercase tracking-wider text-gold">{categoryLabel}</p>
      <h1 class="mt-4 font-serif text-4xl text-cream md:text-6xl">{title}</h1>
      <p class="mt-6 text-lg text-cream-muted">{dek}</p>
      <p class="mt-8 text-xs uppercase tracking-wider text-cream-muted">
        {formatDate(publishDate)} · {runtime}
      </p>
    </header>

    <div class="mx-auto max-w-4xl px-6 py-12">
      <div class="aspect-video bg-navy-soft">
        <iframe
          src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
          title={title}
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
          class="h-full w-full"
        ></iframe>
      </div>
    </div>

    {
      keyTakeaways && keyTakeaways.length > 0 && (
        <section class="mx-auto max-w-3xl px-6 py-8">
          <h2 class="font-serif text-3xl text-cream md:text-4xl">
            Key takeaways
          </h2>
          <ul class="mt-6 space-y-3">
            {keyTakeaways.map((item) => (
              <li class="flex gap-3 text-cream">
                <span class="text-gold" aria-hidden="true">
                  →
                </span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="mx-auto max-w-3xl px-6 py-8">
      <h2 class="font-serif text-3xl text-cream md:text-4xl">Transcript</h2>
      <details class="group mt-4">
        <summary
          class="cursor-pointer text-sm uppercase tracking-wider text-gold underline-offset-4 group-open:underline"
        >
          Show / hide transcript
        </summary>
        <div class="article-prose mt-6">
          <slot />
        </div>
      </details>
    </section>
  </article>

  <NewsletterCTA />
</BaseLayout>
